---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);
const { ebook } = data.ui;
const { landing } = ebook;
---

<BaseLayout
  title={`${ebook.title} — ${data.personal.name}`}
  description={landing.metaDescription}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: ebook.title, url: `/${lang}/ebook/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={ebook.title} subtitle={ebook.subtitle} number="01" as="h1" />

      <!-- Hero: Cover + Form side by side -->
      <div class="scroll-reveal mb-16">
        <div class="grid md:grid-cols-2 gap-px bg-zinc-200 dark:bg-zinc-800">
          <!-- Cover image placeholder -->
          <div class="tile p-8 flex flex-col items-center justify-center text-center">
            <div
              class="w-full max-w-[240px] aspect-3/4 bg-linear-to-br from-accent-500/10 via-accent-500/5 to-electric-500/10 border border-accent-500/20 flex flex-col items-center justify-center p-6 mb-6"
            >
              <span
                class="font-mono text-caption text-accent-500 mb-3 block uppercase tracking-widest"
                >{landing.freeLabel}</span
              >
              <h2
                class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-2 leading-tight"
              >
                {lang === 'fr' ? "L'IA dans l'éducation" : 'AI in Education'}
              </h2>
              <div class="w-8 h-px bg-accent-500/40 my-3"></div>
              <p class="font-mono text-caption text-zinc-500 dark:text-zinc-400">
                {data.personal.name}
              </p>
            </div>
            <div class="flex gap-4">
              <span
                class="font-mono text-caption uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400"
              >
                {landing.pagesLabel}
              </span>
              <span
                class="font-mono text-caption uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400"
              >
                {landing.formatLabel}
              </span>
              <span
                class="font-mono text-caption uppercase tracking-wider px-2 py-1 border border-accent-500/30 text-accent-500"
              >
                {landing.freeLabel}
              </span>
            </div>
          </div>

          <!-- Direct download -->
          <div id="ebook-form" class="tile p-8 flex flex-col justify-center">
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6">
              {landing.heroSubtitle}
            </p>

            <a
              href="/ebook-ia-education.pdf"
              download
              class="group w-full inline-flex items-center justify-center gap-3 px-8 py-4 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-all duration-200"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
              {landing.formCta}
            </a>
            <p class="font-mono text-caption text-zinc-400 dark:text-zinc-500 text-center mt-4">
              {landing.credibilityItems[3]}
            </p>
          </div>
        </div>
      </div>

      <!-- Table of contents / Key takeaways -->
      <div class="scroll-reveal mb-16" style="transition-delay: 100ms">
        <span class="mono-label mb-6 block">{landing.tocTitle}</span>
        <div class="space-y-px bg-zinc-200 dark:bg-zinc-800">
          {
            landing.tocItems.map((item, i) => (
              <div class="tile p-6 flex items-start gap-4">
                <span class="font-mono text-caption text-accent-500 shrink-0 mt-0.5">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <p class="text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed">{item}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Credibility section -->
      <div class="scroll-reveal mb-16" style="transition-delay: 150ms">
        <span class="mono-label mb-6 block">{landing.credibilityTitle}</span>
        <div class="grid md:grid-cols-2 gap-px bg-zinc-200 dark:bg-zinc-800">
          {
            landing.credibilityItems.map((item) => (
              <div class="tile p-6 flex items-start gap-4">
                <span class="font-mono text-caption text-accent-500 shrink-0 mt-0.5">&#10003;</span>
                <p class="text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed">{item}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Key metrics -->
      <div class="scroll-reveal mb-16" style="transition-delay: 175ms">
        <div class="grid grid-cols-3 gap-px bg-zinc-200 dark:bg-zinc-800">
          <div class="tile p-6 text-center">
            <p class="font-display text-2xl font-bold text-accent-500 mb-1">15</p>
            <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
              {lang === 'fr' ? "ans d'expérience" : 'years of experience'}
            </p>
          </div>
          <div class="tile p-6 text-center">
            <p class="font-display text-2xl font-bold text-accent-500 mb-1">6</p>
            <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
              {lang === 'fr' ? 'campus pilotés' : 'campuses managed'}
            </p>
          </div>
          <div class="tile p-6 text-center">
            <p class="font-display text-2xl font-bold text-accent-500 mb-1">400+</p>
            <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
              {lang === 'fr' ? 'apprenants' : 'learners'}
            </p>
          </div>
        </div>
      </div>

      <!-- Testimonial -->
      <div class="scroll-reveal mb-16" style="transition-delay: 200ms">
        <span class="mono-label mb-4 block">{data.ui.testimonials.title}</span>
        <blockquote class="tile p-6">
          <p class="text-sm text-zinc-500 dark:text-zinc-400 italic leading-relaxed mb-3">
            "{landing.testimonialQuote}"
          </p>
          <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
            {landing.testimonialAuthor} — {landing.testimonialRole}
          </p>
        </blockquote>
      </div>

      <!-- Final CTA -->
      <div class="scroll-reveal text-center" style="transition-delay: 250ms">
        <a
          href="#ebook-form"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-all duration-200"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
          {landing.formCta}
          <svg
            class="w-4 h-4 group-hover:-translate-y-0.5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
