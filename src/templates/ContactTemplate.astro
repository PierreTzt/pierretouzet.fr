---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ContactSection from '../components/ContactSection.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);
---

<BaseLayout
  title={`${data.ui.nav.contact} — ${data.personal.name}`}
  description={data.ui.contact.subtitle}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.nav.contact, url: `/${lang}/contact/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <SectionHeader title={data.ui.contact.title} subtitle={data.ui.contact.subtitle} number="01" as="h1" />

      <p class="scroll-reveal text-xs text-zinc-500 dark:text-zinc-400 mb-6 leading-relaxed">
        {lang === 'fr'
          ? 'Ce formulaire ouvre votre client email pour envoyer le message — aucune donnée n\'est stockée sur le site.'
          : "This form opens your email client to send the message — no data is stored on the site."}
        {' '}
        <a href={lang === 'fr' ? '/fr/politique-confidentialite/' : '/en/privacy-policy/'} class="text-accent-500 hover:underline">
          {lang === 'fr' ? 'Politique de confidentialité' : 'Privacy policy'}
        </a>.
      </p>

      <!-- Contact form -->
      <form class="scroll-reveal mb-12 space-y-4" id="contact-form" data-email={data.personal.email}>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="contact-name" class="mono-label mb-1 block">{lang === 'fr' ? 'Nom' : 'Name'}</label>
            <input type="text" id="contact-name" name="name" required
              class="w-full px-4 py-3 text-sm bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 focus:border-accent-500 focus:outline-hidden transition-colors" />
          </div>
          <div>
            <label for="contact-email" class="mono-label mb-1 block">Email</label>
            <input type="email" id="contact-email" name="email" required
              class="w-full px-4 py-3 text-sm bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 focus:border-accent-500 focus:outline-hidden transition-colors" />
          </div>
        </div>
        <div>
          <label for="contact-type" class="mono-label mb-1 block">{lang === 'fr' ? 'Objet' : 'Subject'}</label>
          <select id="contact-type" name="type"
            class="w-full px-4 py-3 text-sm bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 focus:border-accent-500 focus:outline-hidden transition-colors">
            <option value="consulting">{lang === 'fr' ? 'Consulting / Mission' : 'Consulting / Mission'}</option>
            <option value="hiring">{lang === 'fr' ? 'Recrutement' : 'Hiring'}</option>
            <option value="speaking">{lang === 'fr' ? 'Intervention / Conférence' : 'Speaking / Conference'}</option>
            <option value="other">{lang === 'fr' ? 'Autre' : 'Other'}</option>
          </select>
        </div>
        <div>
          <label for="contact-message" class="mono-label mb-1 block">Message</label>
          <textarea id="contact-message" name="message" rows={4} required
            class="w-full px-4 py-3 text-sm bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-900 dark:text-zinc-100 focus:border-accent-500 focus:outline-hidden transition-colors resize-y"></textarea>
        </div>
        <button type="submit"
          class="group flex items-center justify-center gap-3 w-full py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200">
          {lang === 'fr' ? 'Envoyer' : 'Send'}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
        <p id="contact-status" class="text-sm text-center hidden"></p>
      </form>

      <!-- Fallback mailto -->
      <div class="scroll-reveal mb-12 text-center">
        <p class="text-xs text-zinc-400 dark:text-zinc-500 mb-2">{lang === 'fr' ? 'Ou directement par email :' : 'Or directly by email:'}</p>
        <a
          href={`mailto:${data.personal.email}`}
          class="mono-label hover:text-accent-500 transition-colors duration-200"
        >
          {data.personal.email}
        </a>
        <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-4">{lang === 'fr' ? 'Je réponds sous 48h.' : 'I respond within 48 hours.'}</p>
      </div>

      <!-- Cal.com booking -->
      <div class="scroll-reveal mb-12 text-center" style="transition-delay: 40ms">
        <p class="text-xs text-zinc-400 dark:text-zinc-500 mb-3">
          {lang === 'fr' ? 'Ou réservez directement un créneau :' : 'Or book a slot directly:'}
        </p>
        <a
          href="https://cal.com/pierre-tzt/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-all duration-200"
        >
          {lang === 'fr' ? 'Réserver un créneau' : 'Book a slot'}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </a>
      </div>

      <script is:inline>
        document.getElementById('contact-form')?.addEventListener('submit', async function(e) {
          e.preventDefault();
          const form = e.target;
          const status = document.getElementById('contact-status');
          const btn = form.querySelector('button[type="submit"]');
          const recipient = form.dataset.email;
          if (!recipient) return;
          btn.disabled = true;
          btn.textContent = '...';
          try {
            const data = new FormData(form);
            const body = Object.fromEntries(data.entries());
            // Send via mailto fallback (no backend needed)
            const subject = encodeURIComponent(body.type + ': ' + body.name);
            const mailBody = encodeURIComponent('Nom: ' + body.name + '\nEmail: ' + body.email + '\nType: ' + body.type + '\n\n' + body.message);
            window.location.href = 'mailto:' + encodeURIComponent(recipient) + '?subject=' + subject + '&body=' + mailBody;
            status.textContent = document.documentElement.lang === 'fr' ? 'Redirection vers votre client email...' : 'Redirecting to your email client...';
            status.className = 'text-sm text-center text-accent-500';
          } catch (err) {
            status.textContent = document.documentElement.lang === 'fr' ? 'Erreur. Utilisez le lien email ci-dessous.' : 'Error. Please use the email link below.';
            status.className = 'text-sm text-center text-red-500';
          }
          btn.disabled = false;
          btn.textContent = document.documentElement.lang === 'fr' ? 'Envoyer' : 'Send';
        });
      </script>

      <div class="scroll-reveal mb-12" style="transition-delay: 80ms">
        <span class="mono-label mb-4 block">{data.ui.services.title}</span>
        <div class="flex flex-wrap gap-2">
          {data.services.map((s) => (
            <span class="font-mono text-caption uppercase tracking-wider px-3 py-1.5 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
              {s.title}
            </span>
          ))}
        </div>
      </div>

      <ContactSection lang={lang} />
    </div>
  </section>
</BaseLayout>
