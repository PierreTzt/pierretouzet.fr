---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);

const description =
  lang === 'fr'
    ? `Parcours professionnel de ${data.personal.name}`
    : `Professional experience of ${data.personal.name}`;
---

<BaseLayout
  title={`${data.ui.nav.experiences} — ${data.personal.name}`}
  description={description}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.nav.experiences, url: `/${lang}/experiences/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={data.ui.sections.allExperiences} number="01" as="h1" />
      {
        data.experiences.map((exp, i) => (
          <ExperienceCard experience={exp} index={i} isLast={i === data.experiences.length - 1} />
        ))
      }

      <!-- Education -->
      <div class="mt-20">
        <SectionHeader title={data.ui.education} number="02" />
        {
          data.education.map((edu, i) => (
            <div
              class="scroll-reveal group relative grid md:grid-cols-[180px_40px_1fr] grid-cols-[24px_1fr] gap-x-0 md:gap-x-2"
              style={`transition-delay: ${i * 80}ms`}
            >
              {/* Dates desktop */}
              <div class="hidden md:flex flex-col justify-start pt-8">
                <span class="font-mono text-xs text-zinc-500 text-right">
                  {edu.startDate} — {edu.endDate}
                </span>
                <span class="font-mono text-caption text-accent-500 text-right mt-1">
                  {edu.institution}
                </span>
              </div>

              {/* Timeline column */}
              <div class="relative flex flex-col items-center pt-8">
                <div class="relative z-10 w-3 h-3 rounded-full border-2 border-accent-500 bg-white dark:bg-zinc-950 group-hover:bg-accent-500 transition-colors duration-300 shrink-0" />
                {i < data.education.length - 1 && (
                  <div class="w-px flex-1 bg-zinc-200 dark:bg-zinc-800 mt-0" />
                )}
              </div>

              {/* Content */}
              <div class="pb-10">
                <div class="py-6 px-5 -mt-1 hover:bg-zinc-100/50 dark:hover:bg-zinc-900/30 transition-colors duration-200 rounded-lg">
                  <div class="md:hidden mb-2">
                    <span class="font-mono text-xs text-zinc-500">
                      {edu.startDate} — {edu.endDate}
                    </span>
                    <span class="font-mono text-caption text-accent-500 ml-2">
                      {edu.institution}
                    </span>
                  </div>
                  <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-1 group-hover:text-accent-500 transition-colors duration-200">
                    {edu.degree} — {edu.field}
                  </h3>
                  <p class="text-sm text-accent-500 font-medium mb-2 hidden md:block">
                    {edu.institution}
                  </p>
                  {edu.description && (
                    <p class="text-sm text-zinc-500 leading-relaxed">{edu.description}</p>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- CTA -->
      <div class="scroll-reveal mt-16 text-center">
        <a
          href={`/${lang}/contact/`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.contact.letsTalk}
          <svg
            class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
