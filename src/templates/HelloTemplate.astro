---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);
---

<BaseLayout
  title={`${data.ui.hello.title} — ${data.personal.name}`}
  description={lang === 'fr'
    ? "Ingénieur pédagogique, 15 ans entre IT et éducation. De technicien informatique à responsable de 6 campus nationaux."
    : "Instructional designer, 15 years across IT and education. From IT technician to managing 6 national campuses."}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.hello.title, url: lang === 'fr' ? `/${lang}/bonjour/` : `/${lang}/hello/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <!-- Photo -->
      <div class="scroll-reveal mb-8">
        <div class="w-32 h-32 rounded-full overflow-hidden ring-2 ring-accent-500/20 mx-auto">
          <picture>
            <source srcset="/images/pierre-touzet-sm.webp" type="image/webp" />
            <img
              src="/images/pierre-touzet-sm.png"
              alt={data.personal.avatarAlt}
              width="400"
              height="400"
              class="w-full h-full object-cover object-top"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </picture>
        </div>
      </div>

      <!-- Name & title -->
      <div class="scroll-reveal mb-8" style="transition-delay: 80ms">
        <h1 class="font-display text-heading text-zinc-900 dark:text-zinc-50 font-bold mb-2">
          {data.ui.hello.title}
        </h1>
        <p class="text-lg text-zinc-600 dark:text-zinc-400 font-light mb-2">{data.personal.name}</p>
        <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">{data.personal.location}</p>
      </div>

      <!-- Career narrative -->
      <div class="scroll-reveal mb-10 text-left max-w-lg mx-auto" style="transition-delay: 160ms">
        <p class="font-display text-subheading text-zinc-600 dark:text-zinc-400 font-light mb-4 text-center">
          {data.personal.title}
        </p>
        <div class="space-y-3 text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
          <p>{lang === 'fr'
            ? "Bac pro électrotechnique en poche, j'ai commencé comme technicien informatique dans une structure de 2 personnes. Pendant 11 ans, j'ai tout fait : support IT, gestion fournisseurs, graphisme, process — la polyvalence comme école."
            : "With a vocational diploma in electrical engineering, I started as an IT technician in a 2-person company. For 11 years, I did everything: IT support, supplier management, design, process — versatility as my school."}</p>
          <p>{lang === 'fr'
            ? "En 2022, j'ai pivoté vers l'éducation. En moins de 2 ans chez IFAG, j'ai mené la transformation digitale de 28 campus avec un taux d'adoption de 100%. C'est là que j'ai créé Gradly pour automatiser les bulletins RNCP."
            : "In 2022, I pivoted to education. In under 2 years at IFAG, I led the digital transformation of 28 campuses with 100% adoption. That's where I built Gradly to automate RNCP bulletins."}</p>
          <p>{lang === 'fr'
            ? "Aujourd'hui, je pilote seul la stratégie pédagogique de 6 campus nationaux à l'IEFT, avec 11 personnes sur le terrain et 400 apprenants. DPO certifié CNIL, je suis aussi disponible en consulting."
            : "Today, I single-handedly lead the academic strategy across 6 national IEFT campuses, with 11 people on the ground and 400 learners. CNIL-certified DPO, also available for consulting."}</p>
        </div>
      </div>

      <!-- Services tags -->
      <div class="scroll-reveal mb-10" style="transition-delay: 240ms">
        <div class="flex flex-wrap justify-center gap-2">
          {data.services.map((s) => (
            <span class="font-mono text-caption uppercase tracking-wider px-3 py-1.5 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
              {s.title}
            </span>
          ))}
        </div>
      </div>

      <!-- Fun facts -->
      <div class="scroll-reveal mb-10" style="transition-delay: 320ms">
        <div class="grid grid-cols-2 gap-3 max-w-md mx-auto text-left">
          {data.funFacts.map((fact) => (
            <div class="tile p-3 flex items-start gap-2">
              <span class="text-base">{fact.emoji}</span>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{fact.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTAs -->
      <div class="scroll-reveal flex flex-col sm:flex-row items-center justify-center gap-4" style="transition-delay: 400ms">
        <a
          href={`mailto:${data.personal.email}`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.contact.emailMe}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={data.social[0]?.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 px-5 py-2.5 border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-sm font-medium hover:border-accent-500 hover:text-accent-500 transition-colors duration-200"
        >
          LinkedIn
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
          </svg>
        </a>
        <a href={`/${lang}/`} class="mono-label hover:text-accent-500 transition-colors duration-200">
          Portfolio →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
