---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBar from '../components/SkillBar.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);

const description = lang === 'fr'
  ? `Compétences techniques de ${data.personal.name}`
  : `Technical skills of ${data.personal.name}`;

const skillsSlug = lang === 'fr' ? 'competences' : 'skills';
---

<BaseLayout
  title={`${data.ui.nav.skills} — ${data.personal.name}`}
  description={description}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.nav.skills, url: `/${lang}/${skillsSlug}/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <SectionHeader title={data.ui.services.title} number="01" as="h1" />

      <div class="scroll-reveal grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800 mb-16">
        {data.services.map((service, i) => (
          <div class="tile p-8">
            <span class="font-mono text-caption text-accent-500 mb-3 block">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{service.title}</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">{service.description}</p>
            <div class="flex flex-wrap gap-2">
              {service.examples.map((ex) => (
                <span class="font-mono text-caption uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
                  {ex}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <SectionHeader title={data.ui.sections.allSkills} number="02" />

      <div class="scroll-reveal grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
        {data.skillCategories.map((category, catIdx) => (
          <div class="tile p-8">
            <div class="flex items-start gap-3 mb-2">
              {category.icon && (
                <svg class="w-5 h-5 text-accent-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={category.icon} />
                </svg>
              )}
              <p class="mono-label">{category.name}</p>
            </div>
            {category.description && (
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mb-6 leading-relaxed">
                {category.description}
              </p>
            )}
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill, i) => (
                <SkillBar skill={skill} index={catIdx * 6 + i} />
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="scroll-reveal mt-16 text-center">
        <a
          href={`/${lang}/contact/`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.contact.letsTalk}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
