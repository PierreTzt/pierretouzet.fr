---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getData } from '../i18n/utils';
import { getCollection } from 'astro:content';

interface Props {
  lang: 'fr' | 'en';
  post: any;
}

const { lang, post } = Astro.props;
const data = getData(lang);
const dateLocale = lang === 'fr' ? 'fr-FR' : 'en-US';
const updatedLabel = lang === 'fr' ? 'Mis \u00e0 jour le' : 'Updated on';

const wordsPerMinute = 200;
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / wordsPerMinute));

const { Content } = await post.render();

const allPosts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const currentIndex = allPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => ({
    ...p,
    commonTags: p.data.tags.filter((t: string) => post.data.tags.includes(t)).length,
  }))
  .filter(p => p.commonTags > 0)
  .sort((a, b) => b.commonTags - a.commonTags)
  .slice(0, 2);
---

<BaseLayout
  title={`${post.data.title} — ${data.personal.name}`}
  description={post.data.description}
  lang={lang}
  ogImage={`/og/${post.slug}.png`}
  updatedDate={post.data.updatedDate}
  article={{
    publishedTime: post.data.date.toISOString(),
    tags: post.data.tags,
  }}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.blog.title, url: `/${lang}/blog/` },
    { name: post.data.title, url: `/${lang}/blog/${post.slug}/` },
  ]}
>
  <article class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <a
        href={`/${lang}/blog/`}
        class="scroll-reveal group mono-label hover:text-accent-500 transition-colors duration-200 inline-flex items-center gap-2 mb-12"
      >
        <svg class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        {data.ui.blog.backToBlog}
      </a>

      <header class="scroll-reveal mb-12">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag: string) => (
            <span class="font-mono text-caption uppercase tracking-wider px-2 py-0.5 bg-accent-500/10 text-accent-600 dark:text-accent-400">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="font-display text-heading text-zinc-900 dark:text-zinc-50 font-bold mb-4">
          {post.data.title}
        </h1>
        <time class="font-mono text-caption text-zinc-400" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="font-mono text-caption text-zinc-400">&middot; {readingTime} min {lang === 'fr' ? 'de lecture' : 'read'}</span>
        {post.data.updatedDate && (
          <span class="text-zinc-400 dark:text-zinc-500">
            &middot; {updatedLabel} <time datetime={post.data.updatedDate.toISOString()}>
              {post.data.updatedDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </span>
        )}
        <div class="flex items-center gap-3 mt-4">
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(new URL('/' + lang + '/blog/' + post.slug + '/', Astro.site).href)}`}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 font-mono text-caption uppercase tracking-wider text-zinc-400 hover:text-accent-500 transition-colors">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            {lang === 'fr' ? 'Partager' : 'Share'}
          </a>
        </div>
        <div class="h-[1px] bg-gradient-to-r from-accent-500 via-electric-500 to-transparent mt-6"></div>
      </header>

      <div class="scroll-reveal prose prose-zinc dark:prose-invert prose-sm max-w-none prose-headings:font-display prose-headings:font-bold prose-a:text-accent-500 hover:prose-a:text-accent-600" style="transition-delay: 100ms">
        <Content />
      </div>

      <nav class="flex justify-between items-start gap-4 mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800">
        {prevPost ? (
          <a href={`/${lang}/blog/${prevPost.slug}/`} class="group flex flex-col gap-1 text-left">
            <span class="text-caption font-mono uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{lang === 'fr' ? '\u2190 Pr\u00e9c\u00e9dent' : '\u2190 Previous'}</span>
            <span class="text-sm text-zinc-600 dark:text-zinc-300 group-hover:text-accent-500 transition-colors">{prevPost.data.title}</span>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/${lang}/blog/${nextPost.slug}/`} class="group flex flex-col gap-1 text-right ml-auto">
            <span class="text-caption font-mono uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{lang === 'fr' ? 'Suivant \u2192' : 'Next \u2192'}</span>
            <span class="text-sm text-zinc-600 dark:text-zinc-300 group-hover:text-accent-500 transition-colors">{nextPost.data.title}</span>
          </a>
        ) : <div />}
      </nav>

      <!-- Author bio / E-E-A-T -->
      <div class="mt-12 pt-8 border-t border-zinc-200 dark:border-zinc-800">
        <div class="flex items-start gap-4">
          <div class="w-14 h-14 rounded-full overflow-hidden ring-2 ring-accent-500/20 shrink-0">
            <picture>
              <source srcset="/images/pierre-touzet-sm.webp" type="image/webp" />
              <img
                src="/images/pierre-touzet-sm.png"
                alt={data.personal.avatarAlt}
                width="56"
                height="56"
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
            </picture>
          </div>
          <div>
            <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">{data.personal.name}</p>
            <p class="font-mono text-caption text-accent-500 mt-0.5">
              {lang === 'fr' ? 'Ingénieur pédagogique & Innovation digitale' : 'Instructional Designer & Digital Innovation'}
            </p>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mt-2">
              {lang === 'fr'
                ? "15 ans entre IT, pédagogie et innovation digitale. Responsable national des programmes, créateur de Gradly, DPO certifié CNIL."
                : "15 years across IT, education and digital innovation. National Program Director, Gradly creator, CNIL-certified DPO."}
            </p>
            <a
              href={lang === 'fr' ? '/fr/bonjour/' : '/en/hello/'}
              class="mono-label hover:text-accent-500 transition-colors duration-200 mt-2 inline-block"
            >
              {lang === 'fr' ? 'En savoir plus' : 'Learn more'} →
            </a>
          </div>
        </div>
      </div>

      <!-- Article CTA -->
      <div class="mt-8 p-6 tile border-accent-500/20 bg-gradient-to-br from-accent-500/5 via-transparent to-electric-500/5">
        <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
          {lang === 'fr' ? 'Ce sujet vous parle ?' : 'Does this resonate?'}
        </p>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">
          {lang === 'fr'
            ? "Besoin d'un regard expert sur ce sujet ? Discutons-en."
            : "Need expert insight on this topic? Let's discuss."}
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="https://cal.com/pierre-tzt/30min" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-colors">
            {lang === 'fr' ? 'Réserver un échange' : 'Book a call'}
          </a>
          <a href="/ebook-ia-education.pdf" download
            class="inline-flex items-center gap-2 px-5 py-2.5 border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-sm font-medium hover:border-accent-500 hover:text-accent-500 transition-colors">
            {lang === 'fr' ? 'Télécharger mon ebook' : 'Download my ebook'}
          </a>
        </div>
      </div>

      {relatedPosts.length > 0 && (
        <div class="mt-8">
          <span class="mono-label mb-4 block">{lang === 'fr' ? 'Articles similaires' : 'Related articles'}</span>
          <div class="grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
            {relatedPosts.map(related => (
              <a href={`/${lang}/blog/${related.slug}/`} class="tile tile-interactive group p-5">
                <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-accent-500 transition-colors mb-1">{related.data.title}</p>
                <p class="text-xs text-zinc-500 dark:text-zinc-400 line-clamp-2">{related.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-8 text-center">
        <a
          href={`/${lang}/blog/`}
          class="mono-label hover:text-accent-500 transition-colors duration-200"
        >
          &larr; {data.ui.blog.backToBlog}
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
