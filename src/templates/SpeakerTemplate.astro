---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);

const emailSubject = lang === 'fr' ? 'Invitation à intervenir' : 'Speaking invitation';
---

<BaseLayout
  title={`${data.ui.speaker.title} — ${data.personal.name}`}
  description={data.ui.speaker.subtitle}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.speaker.title, url: `/${lang}/speaker/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={data.ui.speaker.title} subtitle={data.ui.speaker.subtitle} number="01" as="h1" />

      <div class="scroll-reveal space-y-px bg-zinc-200 dark:bg-zinc-800 mb-12">
        {data.speakerTopics.map((topic, i) => (
          <div class="tile p-8">
            <div class="flex items-start justify-between gap-4 mb-3">
              <span class="font-mono text-caption text-accent-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="font-mono text-caption uppercase tracking-wider text-zinc-400 dark:text-zinc-500 shrink-0">
                {topic.format}
              </span>
            </div>
            <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">{topic.title}</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">{topic.abstract}</p>
            <div class="flex flex-wrap gap-2">
              {topic.tags.map((tag) => (
                <span class="font-mono text-caption uppercase tracking-wider px-2 py-1 bg-accent-500/10 text-accent-600 dark:text-accent-400">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="scroll-reveal text-center flex flex-wrap justify-center gap-4" style="transition-delay: 300ms">
        <a
          href="https://cal.com/pierre-tzt/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-all duration-200"
        >
          {lang === 'fr' ? 'Réserver un créneau' : 'Book a slot'}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </a>
        <a
          href={`mailto:${data.personal.email}?subject=${encodeURIComponent(emailSubject)}`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.speaker.cta}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
