---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);

const projectsPath = lang === 'fr' ? '/fr/projets/' : '/en/projects/';
const homePath = `/${lang}/`;
---

<BaseLayout
  title={`${data.ui.nav.projects} — ${data.personal.name}`}
  description={lang === 'fr'
    ? `Projets et réalisations de ${data.personal.name}`
    : `Projects and work by ${data.personal.name}`
  }
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: homePath },
    { name: data.ui.nav.projects, url: projectsPath },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <SectionHeader title={data.ui.sections.allProjects} number="01" as="h1" />
      <div class="scroll-reveal grid gap-[1px] bg-zinc-200 dark:bg-zinc-800 md:grid-cols-2 lg:grid-cols-3">
        {data.projects.map((project, i) => (
          <div class="bg-zinc-50 dark:bg-zinc-950">
            <ProjectCard project={project} lang={lang} index={i} />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
