---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);

const emailSubject = lang === 'fr' ? 'Demande de consulting' : 'Consulting request';

const useCases =
  lang === 'fr'
    ? {
        label: 'Vous vous reconnaissez ?',
        items: [
          {
            title: "Vous êtes directeur d'école et vos programmes datent",
            description:
              "Je vous accompagne sur l'audit, la refonte des maquettes et la mise en conformité RNCP/Qualiopi. De la conception à la certification.",
          },
          {
            title: 'Vos équipes pédagogiques perdent du temps sur des tâches administratives',
            description:
              "J'identifie les outils, je déploie, je forme. Objectif : diviser le temps admin par 2 ou 3. Adoption garantie.",
          },
          {
            title:
              "Vous voulez intégrer l'IA dans vos formations mais ne savez pas par où commencer",
            description:
              "Audit de maturité, montée en compétences des équipes, définition d'une stratégie réaliste. Un regard de praticien, pas de théoricien.",
          },
          {
            title:
              "Vous utilisez l'IA dans vos formations et vous ne savez pas si vous êtes conforme",
            description:
              "L'AI Act européen classe les systèmes d'IA éducatifs comme « haut risque » à partir du 2 août 2026. DPO certifié CNIL, j'audite vos usages, identifie les risques et vous accompagne vers la conformité.",
          },
        ],
      }
    : {
        label: 'Sound familiar?',
        items: [
          {
            title: "You're a school director and your programs are outdated",
            description:
              "I'll guide you through auditing, redesigning curricula and achieving RNCP/Qualiopi compliance. From design to certification.",
          },
          {
            title: 'Your academic teams waste time on admin tasks',
            description:
              'I identify the right tools, deploy them, and train your teams. Goal: divide admin time by 2 or 3. Adoption guaranteed.',
          },
          {
            title: "You want to integrate AI into your programs but don't know where to start",
            description:
              "Maturity audit, team upskilling, realistic strategy. A practitioner's perspective, not a theorist's.",
          },
          {
            title: "You use AI in your training and don't know if you're compliant",
            description:
              "The EU AI Act classifies educational AI systems as 'high-risk' from August 2, 2026. As a CNIL-certified DPO, I audit your AI usage, identify risks, and guide you toward compliance.",
          },
        ],
      };

const missionFormats =
  lang === 'fr'
    ? {
        label: 'Formats de mission',
        items: [
          {
            title: 'Diagnostic',
            duration: '1 à 3 jours',
            description: "Audit rapide, recommandations actionnables, plan d'action priorisé.",
          },
          {
            title: 'Mission',
            duration: '1 à 6 mois',
            description: 'Accompagnement complet : conception, déploiement, formation, suivi.',
          },
          {
            title: 'Conseil ponctuel',
            duration: 'À la demande',
            description: 'Échanges ponctuels, revue de projet, expertise ciblée.',
          },
        ],
      }
    : {
        label: 'Mission formats',
        items: [
          {
            title: 'Diagnostic',
            duration: '1 to 3 days',
            description: 'Quick audit, actionable recommendations, prioritized action plan.',
          },
          {
            title: 'Mission',
            duration: '1 to 6 months',
            description: 'Full support: design, deployment, training, follow-up.',
          },
          {
            title: 'Advisory',
            duration: 'On demand',
            description: 'Targeted exchanges, project review, focused expertise.',
          },
        ],
      };
---

<BaseLayout
  title={`${data.ui.consulting.title} — ${data.personal.name}`}
  description={data.ui.consulting.subtitle}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: `/${lang}/` },
    { name: data.ui.consulting.title, url: `/${lang}/consulting/` },
  ]}
>
  <section class="py-20 px-6">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'ProfessionalService',
        name:
          lang === 'fr'
            ? 'Pierre Touzet - Consulting en ingénierie pédagogique'
            : 'Pierre Touzet - Instructional Design Consulting',
        description:
          lang === 'fr'
            ? 'Consultant freelance en ingénierie pédagogique, transformation digitale et certification RNCP/Qualiopi'
            : 'Freelance consultant in instructional design, digital transformation and RNCP/Qualiopi certification',
        url:
          lang === 'fr'
            ? 'https://www.pierretouzet.fr/fr/consulting/'
            : 'https://www.pierretouzet.fr/en/consulting/',
        provider: {
          '@type': 'Person',
          name: 'Pierre Touzet',
          url: 'https://www.pierretouzet.fr',
        },
        areaServed: {
          '@type': 'Country',
          name: 'France',
        },
        serviceType:
          lang === 'fr'
            ? [
                'Ingénierie pédagogique',
                'Transformation digitale',
                'Certification RNCP',
                'Audit Qualiopi',
                'Consulting IA en éducation',
              ]
            : [
                'Instructional design',
                'Digital transformation',
                'RNCP certification',
                'Qualiopi audit',
                'AI consulting in education',
              ],
        hasOfferCatalog: {
          '@type': 'OfferCatalog',
          name: lang === 'fr' ? 'Services de consulting' : 'Consulting services',
          itemListElement: missionFormats.items.map((item) => ({
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: item.title,
              description: item.description,
            },
          })),
        },
      })}
    />
    <div class="max-w-4xl mx-auto">
      <SectionHeader
        title={data.ui.consulting.title}
        subtitle={data.ui.consulting.subtitle}
        number="01"
        as="h1"
      />

      <!-- Services -->
      <div class="scroll-reveal mb-16">
        <span class="mono-label mb-6 block">{data.ui.services.title}</span>
        <div class="grid md:grid-cols-2 gap-px bg-zinc-200 dark:bg-zinc-800">
          {
            data.services.map((service, i) => (
              <div class="tile p-6">
                <span class="font-mono text-caption text-accent-500 mb-3 block">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
                  {service.title}
                </h2>
                <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
                  {service.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {service.examples.map((ex) => (
                    <span class="font-mono text-caption uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
                      {ex}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Process -->
      <div class="scroll-reveal mb-16" style="transition-delay: 100ms">
        <span class="mono-label mb-6 block">{data.ui.process.title}</span>
        <div class="grid md:grid-cols-4 gap-px bg-zinc-200 dark:bg-zinc-800">
          {
            data.processSteps.map((step) => (
              <div class="tile p-6 text-center">
                <span class="font-mono text-caption text-accent-500 mb-2 block">{step.number}</span>
                <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
                  {step.title}
                </h3>
                <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">
                  {step.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Key metrics -->
      <div class="scroll-reveal mb-16" style="transition-delay: 150ms">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-zinc-200 dark:bg-zinc-800">
          {
            data.keyMetrics.map((m) => (
              <div class="tile p-6 text-center">
                <p class="font-display text-2xl font-bold text-accent-500 mb-1">{m.value}</p>
                <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
                  {m.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Gradly proof point -->
      <div class="scroll-reveal mb-16 tile p-6" style="transition-delay: 165ms">
        <div class="flex items-start gap-4">
          <span class="font-mono text-caption text-accent-500 shrink-0 mt-1">★</span>
          <div>
            <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">
              {lang === 'fr' ? 'Exemple concret : Gradly' : 'Concrete example: Gradly'}
            </p>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
              {
                lang === 'fr'
                  ? "Face au constat que les coordinateurs pédagogiques passaient des jours à produire manuellement des bulletins RNCP, j'ai créé Gradly — un outil qui divise le temps administratif par 3. Déployé sur plusieurs campus, 100% offline pour la souveraineté des données."
                  : 'Seeing that academic coordinators spent days manually producing RNCP bulletins, I built Gradly — a tool that divides admin time by 3. Deployed across multiple campuses, 100% offline for data sovereignty.'
              }
            </p>
            <a
              href={lang === 'fr' ? '/fr/projets/gradly/' : '/en/projects/gradly/'}
              class="mono-label hover:text-accent-500 transition-colors mt-2 inline-block"
            >
              {lang === 'fr' ? 'Voir le projet' : 'See the project'} →
            </a>
          </div>
        </div>
      </div>

      <!-- Use cases -->
      <div class="scroll-reveal mb-16" style="transition-delay: 175ms">
        <span class="mono-label mb-6 block">{useCases.label}</span>
        <div class="space-y-px bg-zinc-200 dark:bg-zinc-800">
          {
            useCases.items.map((item) => (
              <div class="tile p-6">
                <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">
                  {item.title}
                </p>
                <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">
                  {item.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Mission formats -->
      <div class="scroll-reveal mb-16" style="transition-delay: 185ms">
        <span class="mono-label mb-6 block">{missionFormats.label}</span>
        <div class="grid md:grid-cols-3 gap-px bg-zinc-200 dark:bg-zinc-800">
          {
            missionFormats.items.map((item) => (
              <div class="tile p-6 text-center">
                <p class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-2">
                  {item.title}
                </p>
                <p class="font-mono text-caption text-accent-500 mb-2">{item.duration}</p>
                <p class="text-xs text-zinc-500 dark:text-zinc-400">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Testimonials -->
      <div class="scroll-reveal mb-16" style="transition-delay: 200ms">
        <span class="mono-label mb-4 block">{data.ui.testimonials.title}</span>
        <div class="space-y-4">
          {
            data.testimonials.slice(0, 2).map((t) => (
              <blockquote class="tile p-6">
                <p class="text-sm text-zinc-500 dark:text-zinc-400 italic leading-relaxed mb-3">
                  "{t.quote}"
                </p>
                <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
                  {t.name} — {t.role}, {t.company}
                </p>
              </blockquote>
            ))
          }
        </div>
      </div>

      <!-- CTA -->
      <div
        class="scroll-reveal text-center flex flex-wrap justify-center gap-4"
        style="transition-delay: 250ms"
      >
        <a
          href="https://cal.com/pierre-tzt/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-all duration-200"
        >
          {lang === 'fr' ? 'Réserver un créneau' : 'Book a slot'}
          <svg
            class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
            ></path>
          </svg>
        </a>
        <a
          href={`mailto:${data.personal.email}?subject=${encodeURIComponent(emailSubject)}`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.contact.letsTalk}
          <svg
            class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
