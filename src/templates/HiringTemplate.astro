---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillBar from '../components/SkillBar.astro';
import { getData } from '../i18n/utils';

interface Props {
  lang: 'fr' | 'en';
}

const { lang } = Astro.props;
const data = getData(lang);
const topSkills = data.skillCategories.flatMap((c) => c.skills).filter((s) => s.highlighted);

const emailSubject = lang === 'fr' ? 'Opportunité de recrutement' : 'Hiring opportunity';
---

<BaseLayout
  title={`${data.ui.hiring.title} — ${data.personal.name}`}
  description={data.ui.hiring.subtitle}
  lang={lang}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={data.ui.hiring.title} subtitle={data.ui.hiring.subtitle} number="01" as="h1" />

      <!-- Why me -->
      <div class="scroll-reveal mb-12">
        <span class="mono-label mb-4 block">{data.ui.hiring.whyMe}</span>
        <div class="grid md:grid-cols-3 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
          {data.keyMetrics.map((m) => (
            <div class="tile p-6 text-center">
              <p class="font-display text-2xl font-bold text-accent-500 mb-1">{m.value}</p>
              <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">{m.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Experiences -->
      <div class="scroll-reveal mb-12" style="transition-delay: 100ms">
        <span class="mono-label mb-6 block">{data.ui.nav.experiences}</span>
        <div class="space-y-6">
          {data.experiences.map((exp) => (
            <div class="tile p-6">
              <div class="flex items-start justify-between gap-4 mb-2">
                <div>
                  <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">{exp.position}</h2>
                  <p class="text-sm text-accent-500 font-medium">{exp.company}</p>
                </div>
                <span class="font-mono text-caption text-zinc-400 shrink-0">{exp.startDate} — {exp.endDate}</span>
              </div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">{exp.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Key skills -->
      <div class="scroll-reveal mb-12" style="transition-delay: 200ms">
        <span class="mono-label mb-4 block">{data.ui.sections.topSkills}</span>
        <div class="flex flex-wrap gap-2">
          {topSkills.map((skill, i) => (
            <SkillBar skill={skill} index={i} />
          ))}
        </div>
      </div>

      <!-- Education -->
      <div class="scroll-reveal mb-12" style="transition-delay: 250ms">
        <span class="mono-label mb-4 block">{data.ui.education}</span>
        <div class="space-y-3">
          {data.education.map((edu) => (
            <div class="tile p-4 flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">{edu.field}</p>
                <p class="font-mono text-caption text-zinc-500">{edu.degree} — {edu.institution}</p>
              </div>
              <span class="font-mono text-caption text-zinc-400 shrink-0">{edu.endDate}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Testimonials -->
      <div class="scroll-reveal mb-12" style="transition-delay: 300ms">
        <span class="mono-label mb-4 block">{data.ui.testimonials.title}</span>
        <div class="space-y-4">
          {data.testimonials.slice(0, 2).map((t) => (
            <blockquote class="tile p-6">
              <p class="text-sm text-zinc-500 dark:text-zinc-400 italic leading-relaxed mb-3">"{t.quote}"</p>
              <p class="font-mono text-caption uppercase tracking-wider text-zinc-500">
                {t.name} — {t.role}, {t.company}
              </p>
            </blockquote>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="scroll-reveal flex flex-col sm:flex-row items-center gap-4" style="transition-delay: 350ms">
        <a
          href={`mailto:${data.personal.email}?subject=${encodeURIComponent(emailSubject)}`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.contact.emailMe}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="/cv-pierre-touzet.pdf"
          download
          class="group inline-flex items-center gap-2 px-5 py-2.5 border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-sm font-medium hover:border-accent-500 hover:text-accent-500 transition-colors duration-200"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          {data.ui.hero.downloadCv}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
