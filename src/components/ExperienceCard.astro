---
import type { Experience } from '../data/types';

interface Props {
  experience: Experience;
  index: number;
}

const { experience, index } = Astro.props;
---

<div
  class="scroll-reveal group"
  style={`transition-delay: ${index * 80}ms`}
>
  <div class="border-t border-zinc-200 dark:border-zinc-800 py-8 grid md:grid-cols-[200px_1fr] gap-6 hover:bg-zinc-100/50 dark:hover:bg-zinc-900/30 -mx-4 px-4 transition-colors duration-200">
    <div class="flex flex-col">
      <span class="font-mono text-xs text-zinc-500 dark:text-zinc-400">
        {experience.startDate} — {experience.endDate}
      </span>
      <span class="font-mono text-xs text-accent-500 mt-1">
        {experience.company}
      </span>
    </div>

    <div>
      <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-2 group-hover:text-accent-500 transition-colors duration-200">
        {experience.position}
      </h3>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4 leading-relaxed">
        {experience.description}
      </p>

      <ul class="space-y-1.5 mb-5">
        {experience.achievements.map((achievement) => (
          <li class="flex items-start gap-2 text-sm text-zinc-600 dark:text-zinc-400">
            <span class="inline-block w-1 h-1 bg-accent-500 mt-2 flex-shrink-0"></span>
            {achievement}
          </li>
        ))}
      </ul>

      <div class="flex flex-wrap gap-2">
        {experience.technologies.map((tech) => (
          <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-800 text-zinc-500 hover:border-accent-500/50 hover:text-accent-500 transition-colors duration-200">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </div>
</div>
