---
import type { Experience } from '../data/types';

interface Props {
  experience: Experience;
  index: number;
  isLast?: boolean;
}

const { experience, index, isLast = false } = Astro.props;
---

<div
  class="scroll-reveal group relative grid md:grid-cols-[180px_40px_1fr] grid-cols-[24px_1fr] gap-x-0 md:gap-x-2"
  style={`transition-delay: ${index * 80}ms`}
>
  <!-- Dates (hidden on mobile, shown on desktop) -->
  <div class="hidden md:flex flex-col justify-start pt-8">
    <span class="font-mono text-xs text-zinc-500 dark:text-zinc-400 text-right">
      {experience.startDate} — {experience.endDate}
    </span>
    <span class="font-mono text-caption text-accent-500 text-right mt-1">
      {experience.company}
    </span>
  </div>

  <!-- Timeline column -->
  <div class="relative flex flex-col items-center pt-8">
    <!-- Dot -->
    <div class="relative z-10 w-3 h-3 rounded-full border-2 border-accent-500 bg-white dark:bg-zinc-950 group-hover:bg-accent-500 transition-colors duration-300 shrink-0"></div>
    <!-- Line -->
    {!isLast && (
      <div class="w-px flex-1 bg-zinc-200 dark:bg-zinc-800 mt-0"></div>
    )}
  </div>

  <!-- Content -->
  <div class="pb-10">
    <div class="py-6 px-5 -mt-1 hover:bg-zinc-100/50 dark:hover:bg-zinc-900/30 transition-colors duration-200 rounded-lg">
      <!-- Mobile dates -->
      <div class="md:hidden mb-2">
        <span class="font-mono text-xs text-zinc-500 dark:text-zinc-400">
          {experience.startDate} — {experience.endDate}
        </span>
        <span class="font-mono text-caption text-accent-500 ml-2">
          {experience.company}
        </span>
      </div>

      <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-2 group-hover:text-accent-500 transition-colors duration-200">
        {experience.position}
      </h3>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4 leading-relaxed">
        {experience.description}
      </p>

      <ul class="space-y-1.5 mb-5">
        {experience.achievements.map((achievement) => (
          <li class="flex items-start gap-2 text-sm text-zinc-600 dark:text-zinc-400">
            <span class="inline-block w-1 h-1 bg-accent-500 mt-2 shrink-0"></span>
            {achievement}
          </li>
        ))}
      </ul>

      <div class="flex flex-wrap gap-2">
        {experience.technologies.map((tech) => (
          <span class="font-mono text-caption uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-800 text-zinc-500 hover:border-accent-500/50 hover:text-accent-500 transition-colors duration-200">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </div>
</div>
