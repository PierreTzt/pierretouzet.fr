---
import type { ProcessStep } from '../data/types';

interface Props {
  steps: ProcessStep[];
  title: string;
  subtitle: string;
}

const { steps, title, subtitle } = Astro.props;
---

<section class="px-6 py-24">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 scroll-reveal">
      <span class="mono-label mb-4 block">{title}</span>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 max-w-lg">{subtitle}</p>
    </div>

    <div class="grid md:grid-cols-4 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
      {steps.map((step, i) => (
        <div
          class="tile p-6 md:p-8 flex flex-col justify-between min-h-[200px] scroll-reveal group"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div>
            <span class="font-mono text-[10px] text-accent-500 mb-4 block">{step.number}</span>
            <h3 class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-3">
              {step.title}
            </h3>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
              {step.description}
            </p>
          </div>
          {i < steps.length - 1 && (
            <div class="hidden md:flex items-center justify-end mt-4">
              <svg class="w-4 h-4 text-zinc-300 dark:text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
