---
import type { Skill } from '../data/types';

interface Props {
  skill: Skill;
  index: number;
}

const { skill, index } = Astro.props;
---

<span
  class="scroll-reveal inline-block font-mono text-[11px] uppercase tracking-wider px-3 py-1.5 border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 hover:border-accent-500/50 hover:text-accent-500 transition-colors duration-200"
  style={`transition-delay: ${index * 40}ms`}
>
  {skill.name}
</span>
