---
import type { Lang } from '../i18n/utils';
import { getData } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { personal, social, ui, funFacts } = getData(lang);
const year = new Date().getFullYear();
const randomFact = funFacts[Math.floor(Math.random() * funFacts.length)];

const iconPaths: Record<string, string> = {
  github:
    'M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z',
  linkedin:
    'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  blog: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z',
};
---

<footer class="border-t border-zinc-200 dark:border-zinc-800">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <p class="font-bold text-sm text-zinc-900 dark:text-zinc-100">{personal.name}</p>
        <p class="font-mono text-xs text-zinc-500 mt-1">{personal.title}</p>
      </div>

      <div class="flex items-center gap-4">
        {
          social.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${link.label} (${lang === 'fr' ? 'nouvel onglet' : 'opens in new tab'})`}
              class="inline-flex items-center justify-center min-w-[24px] min-h-[24px] p-1 text-zinc-500 hover:text-accent-600 transition-colors duration-200"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={iconPaths[link.icon] || ''} />
              </svg>
            </a>
          ))
        }
        <a
          href={`mailto:${personal.email}`}
          aria-label={ui.contact.emailMe}
          class="inline-flex items-center justify-center min-w-[24px] min-h-[24px] p-1 text-zinc-500 hover:text-accent-600 transition-colors duration-200"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
      </div>

      <div class="font-mono text-xs text-zinc-500 text-right">
        <p class="text-caption italic text-zinc-500 dark:text-zinc-400 mb-2">
          {randomFact.emoji}
          {randomFact.text}
        </p>
        <p>&copy; {year} {ui.footer.rights}</p>
        <p class="mt-1">{ui.footer.builtWith}</p>
        <div class="mt-1 flex flex-col items-end gap-0.5">
          <a
            href={lang === 'fr' ? '/fr/mentions-legales/' : '/en/legal/'}
            class="hover:text-accent-500 transition-colors duration-200"
          >
            {ui.footer.legal}
          </a>
          <a
            href={lang === 'fr' ? '/fr/politique-confidentialite/' : '/en/privacy-policy/'}
            class="hover:text-accent-500 transition-colors duration-200"
          >
            {ui.footer.privacy}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
