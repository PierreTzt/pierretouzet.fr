---
import { getLocalizedPath, getOppositeLang, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  label: string;
}

const { lang, label } = Astro.props;
const targetLang = getOppositeLang(lang);
const targetPath = getLocalizedPath(Astro.url.pathname, targetLang);
---

<a
  href={targetPath}
  aria-label={label}
  class="font-mono text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400 hover:text-accent-500 transition-colors duration-200 py-1 px-1"

>
  {targetLang.toUpperCase()}
</a>
