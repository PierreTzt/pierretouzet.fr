---
interface Props {
  title: string;
  subtitle?: string;
  number?: string;
  as?: 'h1' | 'h2';
}

const { title, subtitle, number, as: Tag = 'h2' } = Astro.props;
const words = title.split(' ');
---

<div class="text-reveal mb-16">
  <div class="flex items-baseline gap-4 mb-4">
    {number && (
      <span class="font-mono text-[10px] text-accent-500">{number}</span>
    )}
    <Tag class="font-display text-heading text-zinc-900 dark:text-zinc-50 font-bold">
      {words.map((word, i) => (
        <span class="word" style={`transition-delay: ${i * 60}ms`}>
          <span class="word-inner">{word}</span>
        </span>
        <Fragment>{' '}</Fragment>
      ))}
    </Tag>
  </div>
  {subtitle && (
    <p class="text-sm text-zinc-500 max-w-xl leading-relaxed mt-2">
      {subtitle}
    </p>
  )}
  <div class="mt-6 h-[1px] bg-gradient-to-r from-zinc-200 dark:from-zinc-800 to-transparent"></div>
</div>
