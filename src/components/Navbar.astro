---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import type { Lang } from '../i18n/utils';
import { getData } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const { ui, personal } = getData(lang);

const prefix = `/${lang}`;

const navLinks = [
  { href: `${prefix}/`, label: ui.nav.home },
  { href: `${prefix}/experiences/`, label: ui.nav.experiences },
  { href: `${prefix}/studio/`, label: ui.nav.studio },
  { href: lang === 'fr' ? `${prefix}/competences/` : `${prefix}/skills/`, label: ui.nav.skills },
  { href: `${prefix}/contact/`, label: ui.nav.contact },
  { href: `${prefix}/blog/`, label: ui.blog.title },
];

function isActive(href: string): boolean {
  const clean = currentPath.replace(/\/$/, '');
  const cleanHref = href.replace(/\/$/, '');
  if (cleanHref === prefix) return clean === prefix;
  return clean.startsWith(cleanHref);
}
---

<nav
  aria-label={lang === 'fr' ? 'Navigation principale' : 'Main navigation'}
  class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-200 dark:border-zinc-800 bg-zinc-50/90 dark:bg-zinc-950/90 backdrop-blur-xs"
>
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center justify-between h-14">
      <a
        href={`${prefix}/`}
        class="font-bold text-sm tracking-tight text-zinc-900 dark:text-zinc-100 hover:text-accent-600 dark:hover:text-accent-400 transition-colors duration-200"
      >
        {personal.name}
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-6">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'font-mono text-xs uppercase tracking-wider transition-colors duration-200 py-1 focus:outline-2 focus:outline-offset-2 focus:outline-accent-500',
                isActive(link.href)
                  ? 'text-accent-600 dark:text-accent-400'
                  : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }
        <span class="w-px h-4 bg-zinc-200 dark:bg-zinc-800"></span>
        <LanguageSwitcher lang={lang} label={ui.switchLang} />
        <ThemeToggle label={ui.toggleTheme} />
      </div>

      <!-- Mobile -->
      <div class="flex items-center gap-3 md:hidden">
        <LanguageSwitcher lang={lang} label={ui.switchLang} />
        <ThemeToggle label={ui.toggleTheme} />
        <button
          id="mobile-menu-btn"
          type="button"
          class="p-1 text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-accent-500"
          aria-label={ui.nav.menuLabel}
          aria-expanded="false"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-zinc-200 dark:border-zinc-800 pt-4"
    >
      <div class="flex flex-col gap-3">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'font-mono text-xs uppercase tracking-wider transition-colors duration-200 py-1',
                isActive(link.href)
                  ? 'text-accent-600 dark:text-accent-400'
                  : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</nav>

<script>
  let mobileMenuController: AbortController | undefined;

  function initMobileMenu() {
    mobileMenuController?.abort();
    mobileMenuController = new AbortController();
    const { signal } = mobileMenuController;

    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    // Reset menu state on navigation
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    btn?.addEventListener(
      'click',
      () => {
        const isOpen = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(isOpen));
      },
      { signal },
    );
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
