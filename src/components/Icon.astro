---
/**
 * Reusable Icon component for the most common inline SVG icons.
 * Wraps Heroicons (outline style, 24x24 viewBox) in a consistent API.
 *
 * Usage:
 *   <Icon name="arrow-right" class="w-4 h-4" />
 *
 * Available icons: arrow-right, arrow-top-right, arrow-left, chevron-down, download
 *
 * Note: This component is created for incremental adoption.
 * Existing inline SVGs do NOT need to be replaced all at once.
 */

interface Props {
  name: 'arrow-right' | 'arrow-top-right' | 'arrow-left' | 'chevron-down' | 'download';
  class?: string;
}

const { name, class: className } = Astro.props;

const paths: Record<Props['name'], string> = {
  'arrow-right': 'M17 8l4 4m0 0l-4 4m4-4H3',
  'arrow-top-right': 'M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25',
  'arrow-left': 'M7 16l-4-4m0 0l4-4m-4 4h18',
  'chevron-down': 'M19 9l-7 7-7-7',
  download:
    'M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
  viewBox="0 0 24 24"
  stroke-width="1.5"
  stroke="currentColor"
  class={className}
  aria-hidden="true"
>
  <path stroke-linecap="round" stroke-linejoin="round" d={paths[name]}></path>
</svg>
