---
import type { BrandData } from '../../data/types';

interface Props {
  voice: BrandData['voice'];
}

const { voice } = Astro.props;
---

<section
  id="voice"
  class="brand-section border-t border-zinc-200 dark:border-zinc-800 py-24 md:py-32 lg:py-40 px-6 md:px-8"
>
  <div class="max-w-6xl mx-auto">
    <p class="mono-label scroll-reveal mb-6">{voice.eyebrow}</p>
    <h2
      class="scroll-reveal font-display text-heading tracking-[-0.02em] text-zinc-900 dark:text-zinc-50 mb-6 max-w-3xl"
      style="transition-delay: 100ms"
    >
      {voice.heading}
    </h2>
    <p
      class="scroll-reveal text-base md:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mb-16"
      style="transition-delay: 200ms"
    >
      {voice.intro}
    </p>

    <div class="scroll-reveal grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-200 dark:bg-zinc-800 mb-24">
      {
        voice.principles.map((principle, i) => (
          <div class="tile p-8 bg-white dark:bg-zinc-950">
            <p class="font-mono text-caption text-accent-500 mb-4">
              {String(i + 1).padStart(2, '0')}
            </p>
            <h3 class="font-display text-xl md:text-2xl font-semibold text-zinc-900 dark:text-zinc-50 mb-3">
              {principle.title}
            </h3>
            <p class="text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed">
              {principle.description}
            </p>
          </div>
        ))
      }
    </div>

    <div class="scroll-reveal grid grid-cols-1 md:grid-cols-2 gap-px bg-zinc-200 dark:bg-zinc-800">
      <div class="bg-white dark:bg-zinc-950 p-8">
        <p class="font-mono text-caption text-emerald-600 dark:text-emerald-400 mb-6 uppercase tracking-[0.15em]">
          {voice.doLabel}
        </p>
        <ul class="space-y-6">
          {
            voice.doDont.map((row) => (
              <li class="text-sm md:text-base text-zinc-800 dark:text-zinc-200 leading-relaxed">
                {row.do}
              </li>
            ))
          }
        </ul>
      </div>
      <div class="bg-white dark:bg-zinc-950 p-8">
        <p class="font-mono text-caption text-rose-600 dark:text-rose-400 mb-6 uppercase tracking-[0.15em]">
          {voice.dontLabel}
        </p>
        <ul class="space-y-6">
          {
            voice.doDont.map((row) => (
              <li class="text-sm md:text-base text-zinc-500 dark:text-zinc-500 leading-relaxed line-through decoration-zinc-400/40">
                {row.dont}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
