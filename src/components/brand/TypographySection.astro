---
import type { BrandData } from '../../data/types';

interface Props {
  typography: BrandData['typography'];
}

const { typography } = Astro.props;
---

<section
  id="typography"
  class="brand-section border-t border-zinc-200 dark:border-zinc-800 py-24 md:py-32 lg:py-40 px-6 md:px-8"
>
  <div class="max-w-6xl mx-auto">
    <p class="mono-label scroll-reveal mb-6">{typography.eyebrow}</p>
    <h2
      class="scroll-reveal font-display text-heading tracking-[-0.02em] text-zinc-900 dark:text-zinc-50 mb-6 max-w-3xl"
      style="transition-delay: 100ms"
    >
      {typography.heading}
    </h2>
    <p
      class="scroll-reveal text-base md:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mb-16"
      style="transition-delay: 200ms"
    >
      {typography.intro}
    </p>

    <div class="scroll-reveal grid grid-cols-1 md:grid-cols-2 gap-px bg-zinc-200 dark:bg-zinc-800 mb-24">
      {
        typography.pairings.map((pairing) => (
          <div
            class="tile p-8 md:p-10 bg-white dark:bg-zinc-950"
            title={pairing.tailwindClass}
          >
            <p class="mono-label mb-4">{pairing.family} · {pairing.role}</p>
            <p
              class:list={[
                'text-zinc-900 dark:text-zinc-50 mb-6 leading-[0.95]',
                pairing.family === 'Sora' ? 'font-display text-5xl md:text-6xl font-bold' : 'font-sans text-lg md:text-xl',
              ]}
            >
              {pairing.specimenText}
            </p>
            <p class="font-mono text-xs text-zinc-500 dark:text-zinc-400">{pairing.weights}</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-zinc-400 dark:text-zinc-500 mt-2">
              {pairing.tailwindClass}
            </p>
          </div>
        ))
      }
    </div>

    <h3
      class="scroll-reveal font-display text-subheading tracking-[-0.01em] text-zinc-900 dark:text-zinc-50 mb-10"
    >
      {typography.scaleHeading}
    </h3>
    <div class="scroll-reveal space-y-10">
      {
        typography.scale.map((item) => (
          <div class="grid grid-cols-1 md:grid-cols-[200px_1fr_200px] gap-6 md:gap-8 items-baseline border-b border-zinc-200 dark:border-zinc-800 pb-8">
            <div>
              <p class="mono-label">{item.label}</p>
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-zinc-400 dark:text-zinc-500 mt-1">
                {item.token}
              </p>
            </div>
            <p
              class:list={[
                item.tailwindClass,
                'font-display text-zinc-900 dark:text-zinc-50 leading-none',
              ]}
              title={item.tailwindClass}
            >
              {item.example}
            </p>
            <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-zinc-400 dark:text-zinc-500 md:text-right">
              .{item.tailwindClass}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
