---
import type { BrandData } from '../../data/types';

interface Props {
  palette: BrandData['palette'];
  copyFeedback: string;
}

const { palette, copyFeedback } = Astro.props;
---

<section
  id="palette"
  class="brand-section border-t border-zinc-200 dark:border-zinc-800 py-24 md:py-32 lg:py-40 px-6 md:px-8"
>
  <div class="max-w-6xl mx-auto">
    <p class="mono-label scroll-reveal mb-6">{palette.eyebrow}</p>
    <h2
      class="scroll-reveal font-display text-heading tracking-[-0.02em] text-zinc-900 dark:text-zinc-50 mb-6 max-w-3xl"
      style="transition-delay: 100ms"
    >
      {palette.heading}
    </h2>
    <p
      class="scroll-reveal text-base md:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mb-16"
      style="transition-delay: 200ms"
    >
      {palette.intro}
    </p>

    <div class="scroll-reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-zinc-200 dark:bg-zinc-800">
      {
        palette.tokens.map((token) => {
          const valueToCopy = token.hex;
          const displayValue = token.displayValue ?? token.hex;
          return (
            <button
              type="button"
              data-copy={valueToCopy}
              data-copy-feedback={copyFeedback}
              aria-label={`Copier ${token.name} (${displayValue})`}
              class="group flex flex-col text-left bg-white dark:bg-zinc-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500 focus-visible:z-10 relative"
            >
              <div
                class:list={[
                  'h-32',
                  token.tailwindClass,
                  token.onDark ? 'border-b border-zinc-700' : '',
                ]}
                aria-hidden="true"
              />
              <div class="p-4 space-y-1">
                <p class="font-semibold text-sm text-zinc-900 dark:text-zinc-100">
                  {token.name}
                </p>
                <p class="swatch-value font-mono text-xs text-zinc-500 dark:text-zinc-400">
                  {displayValue}
                </p>
                <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-zinc-400 dark:text-zinc-500">
                  {token.tailwindClass}
                </p>
                <p class="text-xs text-zinc-500 dark:text-zinc-400 pt-1">{token.usage}</p>
              </div>
            </button>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  import '../../scripts/brand-copy';
</script>
