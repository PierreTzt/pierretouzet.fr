---
import type { BrandData } from '../../data/types';

interface Props {
  manifesto: BrandData['manifesto'];
}

const { manifesto } = Astro.props;
---

<section
  id="manifesto"
  class="brand-section py-24 md:py-32 lg:py-40 px-6 md:px-8"
>
  <div class="max-w-6xl mx-auto">
    <p class="mono-label scroll-reveal mb-8">{manifesto.eyebrow}</p>
    <h1
      class="scroll-reveal font-display text-display leading-[0.9] tracking-[-0.03em] text-zinc-900 dark:text-zinc-50 mb-16 max-w-5xl"
      style="transition-delay: 100ms"
    >
      {manifesto.headline}
    </h1>
    <div class="space-y-6 max-w-3xl">
      {
        manifesto.paragraphs.map((paragraph, i) => (
          <p
            class="scroll-reveal text-lg md:text-xl leading-relaxed text-zinc-700 dark:text-zinc-300"
            style={`transition-delay: ${200 + i * 100}ms`}
          >
            {paragraph}
          </p>
        ))
      }
    </div>
  </div>
</section>
