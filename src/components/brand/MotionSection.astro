---
import type { BrandData } from '../../data/types';

interface Props {
  motion: BrandData['motion'];
}

const { motion } = Astro.props;
---

<section
  id="motion"
  class="brand-section border-t border-zinc-200 dark:border-zinc-800 py-24 md:py-32 lg:py-40 px-6 md:px-8"
>
  <div class="max-w-6xl mx-auto">
    <p class="mono-label scroll-reveal mb-6">{motion.eyebrow}</p>
    <h2
      class="scroll-reveal font-display text-heading tracking-[-0.02em] text-zinc-900 dark:text-zinc-50 mb-6 max-w-3xl"
      style="transition-delay: 100ms"
    >
      {motion.heading}
    </h2>
    <p
      class="scroll-reveal text-base md:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mb-16"
      style="transition-delay: 200ms"
    >
      {motion.intro}
    </p>

    <div class="scroll-reveal grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-200 dark:bg-zinc-800 mb-24">
      {
        motion.principles.map((principle, i) => (
          <div class="tile p-8 bg-white dark:bg-zinc-950">
            <p class="font-mono text-caption text-accent-500 mb-4">
              {String(i + 1).padStart(2, '0')}
            </p>
            <h3 class="font-display text-xl md:text-2xl font-semibold text-zinc-900 dark:text-zinc-50 mb-3">
              {principle.title}
            </h3>
            <p class="text-sm md:text-base text-zinc-600 dark:text-zinc-400 leading-relaxed mb-4">
              {principle.description}
            </p>
            {principle.utilityClass && (
              <p class="font-mono text-[10px] uppercase tracking-[0.15em] text-zinc-400 dark:text-zinc-500">
                {principle.utilityClass}
              </p>
            )}
          </div>
        ))
      }
    </div>

    <h3
      class="scroll-reveal font-display text-subheading tracking-[-0.01em] text-zinc-900 dark:text-zinc-50 mb-4"
    >
      {motion.motifsHeading}
    </h3>
    <p class="mono-label scroll-reveal mb-10">{motion.motifsHint}</p>

    <div class="scroll-reveal grid grid-cols-1 md:grid-cols-3 gap-px bg-zinc-200 dark:bg-zinc-800">
      <div class="bg-white dark:bg-zinc-950 p-10 flex items-center justify-center min-h-[180px]">
        <span class="brand-link-demo font-display text-2xl md:text-3xl font-semibold text-zinc-900 dark:text-zinc-50 relative">
          link-hover
        </span>
      </div>

      <div class="bg-white dark:bg-zinc-950 p-10 flex items-center justify-center min-h-[180px]">
        <div class="tile tile-interactive glow-hover p-6 w-full max-w-[220px] text-center cursor-default">
          <p class="font-mono text-caption text-accent-500 mb-2">TILE</p>
          <p class="font-display text-lg text-zinc-900 dark:text-zinc-50">glow-hover</p>
        </div>
      </div>

      <div class="bg-white dark:bg-zinc-950 p-10 flex items-center justify-center min-h-[180px]">
        <div class="brand-grain-sample relative w-full max-w-[220px] aspect-square bg-zinc-900 dark:bg-zinc-800 flex items-center justify-center">
          <p class="font-mono text-caption text-zinc-300 uppercase tracking-[0.15em] relative z-10">
            grain
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .brand-link-demo::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--color-accent-500);
    animation: brand-link-loop 3s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  @keyframes brand-link-loop {
    0% {
      width: 0;
    }
    40% {
      width: 100%;
    }
    60% {
      width: 100%;
    }
    100% {
      width: 0;
    }
  }

  .brand-grain-sample::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.25'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    pointer-events: none;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-link-demo::after {
      animation: none;
      width: 100%;
    }
  }
</style>
