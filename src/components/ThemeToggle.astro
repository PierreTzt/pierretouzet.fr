---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button
  data-theme-toggle
  type="button"
  aria-label={label}
  class="theme-toggle p-2 text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors duration-200"
>
  <!-- Sun icon (visible in dark mode → click to go light) -->
  <svg
    class="theme-icon theme-icon--sun w-4 h-4"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    ></path>
  </svg>
  <!-- Moon icon (visible in light mode → click to go dark) -->
  <svg
    class="theme-icon theme-icon--moon w-4 h-4"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="1.5"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    ></path>
  </svg>
</button>

<style>
  .theme-toggle {
    position: relative;
    overflow: hidden;
  }

  .theme-icon {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
                opacity 0.3s ease;
  }

  /* Light mode: show moon (to switch to dark), hide sun */
  .theme-icon--sun {
    position: absolute;
    inset: 0;
    margin: auto;
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }

  .theme-icon--moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  /* Dark mode: show sun (to switch to light), hide moon */
  :global(.dark) .theme-icon--sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  :global(.dark) .theme-icon--moon {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-icon {
      transition: none;
    }
  }
</style>

<script>
  let themeToggleController: AbortController | undefined;

  function initThemeToggle() {
    themeToggleController?.abort();
    themeToggleController = new AbortController();
    const { signal } = themeToggleController;

    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }, { signal });
    });
  }
  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
