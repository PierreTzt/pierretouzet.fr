---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button
  data-theme-toggle
  type="button"
  aria-label={label}
  class="theme-toggle p-2 text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors duration-200"
>
  <svg class="theme-icon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <!-- Sun rays (hidden in dark mode) -->
    <g class="sun-rays">
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </g>
    <!-- Sun/Moon circle -->
    <circle class="sun-core" cx="12" cy="12" r="5" />
    <!-- Moon mask (clips the circle in dark mode) -->
    <circle class="moon-mask" cx="16" cy="8" r="0" fill="var(--bg-color, #fafafa)" stroke="none" />
  </svg>
</button>

<style>
  .theme-toggle {
    --bg-color: #fafafa;
  }

  :global(.dark) .theme-toggle {
    --bg-color: #09090b;
  }

  .theme-icon {
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .theme-toggle:active .theme-icon {
    transform: rotate(30deg);
  }

  .sun-rays line {
    transform-origin: center;
    transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sun-core {
    transition: r 0.3s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .moon-mask {
    transition: r 0.3s ease 0.1s, cx 0.3s ease 0.1s;
  }

  /* Dark mode: morph into moon */
  :global(.dark) .theme-icon {
    transform: rotate(-45deg);
  }

  :global(.dark) .sun-rays line {
    opacity: 0;
    transform: scale(0);
  }

  :global(.dark) .sun-core {
    r: 7;
  }

  :global(.dark) .moon-mask {
    r: 6;
    cx: 17;
  }
</style>

<script>
  function initThemeToggle() {
    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    });
  }
  initThemeToggle();
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
