---
import type { Lang } from '../i18n/utils';
import { getData } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { personal, social, ui } = getData(lang);

const contactLinks = [
  {
    label: ui.contact.emailMe,
    href: `mailto:${personal.email}`,
    detail: personal.email,
    mono: 'EMAIL',
  },
  ...social.map((s) => ({
    label: s.platform,
    href: s.url,
    detail: s.url.replace('https://', ''),
    mono: s.platform.toUpperCase(),
  })),
];
---

<div class="space-y-0">
  {contactLinks.map((link, i) => (
    <a
      href={link.href}
      target={link.mono !== 'EMAIL' ? '_blank' : undefined}
      rel={link.mono !== 'EMAIL' ? 'noopener noreferrer' : undefined}
      class="scroll-reveal group flex items-center justify-between py-6 border-t border-zinc-200 dark:border-zinc-800 transition-colors duration-200 hover:bg-zinc-100/50 dark:hover:bg-zinc-900/50 -mx-4 px-4 focus:outline-2 focus:outline-offset-2 focus:outline-accent-500"
      style={`transition-delay: ${i * 80}ms`}
      aria-label={link.label}
    >
      <div class="flex items-center gap-4">
        <span class="font-mono text-[10px] uppercase tracking-wider text-accent-500 w-16">
          {link.mono}
        </span>
        <div>
          <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-accent-500 transition-colors duration-200">
            {link.label}
          </p>
          <p class="font-mono text-xs text-zinc-500 mt-0.5">{link.detail}</p>
        </div>
      </div>
      <svg class="w-4 h-4 text-zinc-400 group-hover:text-accent-500 group-hover:translate-x-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
      </svg>
    </a>
  ))}
</div>
