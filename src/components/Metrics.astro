---
import type { KeyMetric } from '../data/types';

interface Props {
  metrics: KeyMetric[];
  trustedBy?: string;
}

const { metrics, trustedBy } = Astro.props;
---

<section class="px-6 pb-[1px]">
  <div class="max-w-7xl mx-auto">
    <div class="scroll-reveal grid grid-cols-2 md:grid-cols-4 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
      {metrics.map((metric, i) => (
        <div class="tile p-6 md:p-8 text-center">
          <p class="font-display text-heading font-bold bg-gradient-to-r from-accent-500 to-electric-500 bg-clip-text text-transparent mb-1">
            {metric.value}
          </p>
          <p class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
            {metric.label}
          </p>
        </div>
      ))}
    </div>
    {trustedBy && (
      <div class="tile py-4 px-6 scroll-reveal">
        <div class="flex items-center justify-center gap-6 flex-wrap">
          <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{trustedBy}</span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 font-medium">IEFT</span>
          <span class="text-zinc-300 dark:text-zinc-700">·</span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 font-medium">IFAG</span>
          <span class="text-zinc-300 dark:text-zinc-700">·</span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 font-medium">ICM</span>
          <span class="text-zinc-300 dark:text-zinc-700">·</span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 font-medium">Compétences & Développement</span>
        </div>
      </div>
    )}
  </div>
</section>
