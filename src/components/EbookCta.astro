---
import type { Lang } from '../i18n/utils';
import { getData } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { ui } = getData(lang);
---

<section aria-label={ui.ebook.title} class="px-6 pb-24">
  <div class="max-w-7xl mx-auto">
    <div class="scroll-reveal tile p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 border border-accent-500/20 bg-linear-to-br from-accent-500/5 via-transparent to-electric-500/5">
      <div class="max-w-lg">
        <span class="mono-label mb-3 block text-accent-500">Ebook</span>
        <h2 class="font-display text-lg md:text-xl font-bold text-zinc-900 dark:text-zinc-100 mb-3">
          {ui.ebook.title}
        </h2>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
          {ui.ebook.subtitle}
        </p>
      </div>
      <a
        href={`/${lang}/ebook/`}
        class="group shrink-0 inline-flex items-center gap-3 px-8 py-4 bg-accent-500 text-white text-sm font-medium hover:bg-accent-600 transition-all duration-200"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {ui.ebook.cta}
      </a>
    </div>
  </div>
</section>
