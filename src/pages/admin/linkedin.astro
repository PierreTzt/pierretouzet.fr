---
export const prerender = false;
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const blogArticles = posts.map(p => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  date: p.data.date.toISOString().slice(0, 10),
  lang: p.data.lang,
  tags: p.data.tags,
}));
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>LinkedIn Studio — Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Inter, system-ui, sans-serif; background: #fafafa; color: #18181b; }
    .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
    h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; }
    .subtitle { font-size: 0.8125rem; color: #71717a; margin-bottom: 2rem; font-family: ui-monospace, monospace; }

    /* Nav */
    .admin-nav { display: flex; gap: 1.5rem; margin-bottom: 2rem; font-size: 0.8125rem; font-family: ui-monospace, monospace; }
    .admin-nav a { color: #71717a; text-decoration: none; }
    .admin-nav a:hover { color: #4f46e5; }
    .admin-nav a.active { color: #4f46e5; font-weight: 600; }

    /* Form elements */
    label { display: block; font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin-bottom: 0.375rem; font-family: ui-monospace, monospace; }
    input, select, textarea { width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e4e4e7; background: white; font-size: 0.875rem; font-family: inherit; outline: none; transition: border-color 0.15s; }
    input:focus, select:focus, textarea:focus { border-color: #4f46e5; }
    textarea { resize: vertical; line-height: 1.6; }

    .field { margin-bottom: 1.25rem; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; font-size: 0.8125rem; font-weight: 500; font-family: inherit; border: none; cursor: pointer; transition: all 0.15s; }
    .btn-primary { background: #18181b; color: white; }
    .btn-primary:hover:not(:disabled) { background: #4f46e5; }
    .btn-accent { background: #4f46e5; color: white; }
    .btn-accent:hover:not(:disabled) { background: #4338ca; }
    .btn-ghost { background: transparent; color: #71717a; border: 1px solid #e4e4e7; }
    .btn-ghost:hover:not(:disabled) { color: #18181b; border-color: #a1a1aa; }
    .btn-sm { padding: 0.375rem 0.75rem; font-size: 0.75rem; }
    .btn-danger { background: transparent; color: #ef4444; border: 1px solid #fecaca; }
    .btn-danger:hover { background: #fef2f2; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; }

    /* Sections */
    .card { background: white; border: 1px solid #e4e4e7; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card-header { font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: #4f46e5; margin-bottom: 1rem; font-family: ui-monospace, monospace; }

    /* Main tabs */
    .main-tabs { display: flex; gap: 0; margin-bottom: 1.5rem; border-bottom: 1px solid #e4e4e7; }
    .main-tab { padding: 0.625rem 1.25rem; font-size: 0.8125rem; font-family: ui-monospace, monospace; cursor: pointer; border: none; background: transparent; color: #71717a; border-bottom: 2px solid transparent; transition: all 0.15s; }
    .main-tab:hover { color: #18181b; }
    .main-tab.active { color: #4f46e5; border-bottom-color: #4f46e5; font-weight: 600; }

    /* Format selector */
    .format-options { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.75rem; margin-top: 0.375rem; }
    .format-option { position: relative; }
    .format-option input { position: absolute; opacity: 0; pointer-events: none; }
    .format-option label {
      display: flex; flex-direction: column; gap: 0.25rem;
      padding: 0.875rem; border: 2px solid #e4e4e7; cursor: pointer;
      transition: all 0.15s; text-transform: none; letter-spacing: normal;
      font-family: inherit; font-size: 0.8125rem; font-weight: 500; color: #18181b;
    }
    .format-option label span { font-size: 0.6875rem; font-weight: 400; color: #71717a; }
    .format-option input:checked + label { border-color: #4f46e5; background: rgba(79, 70, 229, 0.04); }
    .format-option label:hover { border-color: #a1a1aa; }

    /* Status */
    .status { font-size: 0.75rem; color: #71717a; font-family: ui-monospace, monospace; padding: 0.75rem 0; }
    .status.error { color: #ef4444; }
    .status.success { color: #22c55e; }

    /* Spinner */
    .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; border-top-color: white; animation: spin 0.6s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .hidden { display: none; }

    /* Two-column layout for step 2 */
    .edit-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 768px) { .edit-layout { grid-template-columns: 1fr; } .format-options { grid-template-columns: 1fr; } }

    /* Visual preview */
    .visual-preview { background: #f4f4f5; border: 1px solid #e4e4e7; display: flex; align-items: center; justify-content: center; padding: 1rem; min-height: 200px; }
    .visual-preview img { max-width: 100%; max-height: 400px; object-fit: contain; }
    .visual-preview .placeholder { color: #71717a; font-size: 0.8125rem; font-family: ui-monospace, monospace; }

    /* Size selector */
    .size-options { display: flex; gap: 0.5rem; margin-top: 0.375rem; }
    .size-option { position: relative; }
    .size-option input { position: absolute; opacity: 0; pointer-events: none; }
    .size-option label {
      display: inline-flex; align-items: center; gap: 0.375rem;
      padding: 0.375rem 0.75rem; border: 1px solid #e4e4e7; cursor: pointer;
      font-size: 0.6875rem; font-family: ui-monospace, monospace; color: #71717a;
      text-transform: none; letter-spacing: normal; transition: all 0.15s;
    }
    .size-option input:checked + label { border-color: #4f46e5; color: #4f46e5; background: rgba(79, 70, 229, 0.04); }
    .size-option label:hover { border-color: #a1a1aa; }

    /* LinkedIn preview mock */
    .linkedin-mock { background: white; border: 1px solid #e4e4e7; padding: 1rem; margin-top: 1.5rem; }
    .linkedin-mock-header { display: flex; gap: 0.625rem; align-items: flex-start; margin-bottom: 0.75rem; }
    .linkedin-mock-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .linkedin-mock-meta { display: flex; flex-direction: column; }
    .linkedin-mock-name { font-size: 0.8125rem; font-weight: 600; color: #18181b; }
    .linkedin-mock-title { font-size: 0.6875rem; color: #71717a; line-height: 1.3; }
    .linkedin-mock-time { font-size: 0.625rem; color: #a1a1aa; }
    .linkedin-mock-body { font-size: 0.8125rem; line-height: 1.5; color: #18181b; white-space: pre-line; margin-bottom: 0.75rem; }
    .linkedin-mock-truncated { max-height: 4.5em; overflow: hidden; position: relative; }
    .linkedin-mock-truncated::after { content: '...voir plus'; position: absolute; bottom: 0; right: 0; background: white; padding-left: 0.25rem; color: #71717a; font-weight: 500; font-size: 0.8125rem; }
    .linkedin-mock-image { width: 100%; margin-bottom: 0.75rem; }
    .linkedin-mock-image img { width: 100%; display: block; }
    .linkedin-mock-actions { display: flex; gap: 1rem; padding-top: 0.5rem; border-top: 1px solid #e4e4e7; }
    .linkedin-mock-action { display: flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; color: #71717a; }

    /* Export buttons */
    .export-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn-copy-ok { background: #22c55e; color: white; }

    /* Veille items */
    .veille-item { display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.75rem; border: 1px solid #e4e4e7; margin-bottom: 0.5rem; background: white; }
    .veille-item-content { flex: 1; }
    .veille-item-title { font-size: 0.8125rem; font-weight: 500; color: #18181b; margin-bottom: 0.25rem; }
    .veille-item-url { font-size: 0.6875rem; color: #4f46e5; word-break: break-all; }
    .veille-item-note { font-size: 0.75rem; color: #71717a; margin-top: 0.25rem; }
    .veille-item-date { font-size: 0.625rem; color: #a1a1aa; font-family: ui-monospace, monospace; }
    .veille-empty { padding: 2rem; text-align: center; color: #a1a1aa; font-size: 0.8125rem; border: 1px dashed #e4e4e7; }
    .veille-counter { font-size: 0.75rem; color: #71717a; font-family: ui-monospace, monospace; margin-bottom: 1rem; }

    /* Blog articles list */
    .blog-item { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem; border: 1px solid #e4e4e7; margin-bottom: 0.5rem; background: white; }
    .blog-item-info { flex: 1; }
    .blog-item-title { font-size: 0.8125rem; font-weight: 500; color: #18181b; }
    .blog-item-meta { font-size: 0.6875rem; color: #71717a; margin-top: 0.125rem; }
    .blog-item-meta .lang { text-transform: uppercase; font-weight: 600; color: #4f46e5; }

    /* Feedback */
    .feedback-zone { display: flex; gap: 0.5rem; align-items: flex-end; margin-top: 0.75rem; }
    .feedback-zone input { flex: 1; font-size: 0.75rem; padding: 0.375rem 0.625rem; }
    .feedback-prefs { margin-top: 0.75rem; }
    .feedback-pref { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; padding: 0.25rem 0.5rem; background: #fef2f2; color: #ef4444; margin: 0.125rem; border: 1px solid #fecaca; }
    .feedback-pref button { background: none; border: none; color: #ef4444; cursor: pointer; font-size: 0.75rem; padding: 0 0.125rem; }

    /* Tags input (export) */
    .tags-container { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.375rem; }
    .tag { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.625rem; background: rgba(79, 70, 229, 0.08); color: #4f46e5; font-family: ui-monospace, monospace; }
    .tag button { background: none; border: none; color: #4f46e5; cursor: pointer; font-size: 0.875rem; line-height: 1; padding: 0 0.125rem; }

    /* History */
    .history-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
    .stat-card { background: white; border: 1px solid #e4e4e7; padding: 1rem; text-align: center; }
    .stat-value { font-size: 1.5rem; font-weight: 700; color: #18181b; }
    .stat-label { font-size: 0.6875rem; color: #71717a; font-family: ui-monospace, monospace; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
    .tag-cloud { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.5rem; }
    .tag-cloud-item { font-size: 0.6875rem; padding: 0.25rem 0.5rem; background: rgba(79, 70, 229, 0.08); color: #4f46e5; font-family: ui-monospace, monospace; }
    .history-month { font-size: 0.75rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.05em; font-family: ui-monospace, monospace; margin: 1rem 0 0.5rem; }
    .history-item { display: flex; gap: 0.75rem; padding: 0.75rem; border: 1px solid #e4e4e7; margin-bottom: 0.5rem; background: white; }
    .history-item-content { flex: 1; }
    .history-item-headline { font-size: 0.8125rem; font-weight: 500; color: #18181b; }
    .history-item-excerpt { font-size: 0.75rem; color: #71717a; margin-top: 0.25rem; max-height: 2.25em; overflow: hidden; }
    .history-item-meta { display: flex; gap: 0.75rem; align-items: center; margin-top: 0.375rem; font-size: 0.625rem; font-family: ui-monospace, monospace; color: #a1a1aa; }
    .history-item-format { text-transform: uppercase; font-weight: 600; color: #4f46e5; }
    .history-metrics { display: flex; gap: 0.5rem; align-items: center; }
    .history-metrics input { width: 3.5rem; padding: 0.25rem 0.375rem; font-size: 0.6875rem; text-align: center; border: 1px solid #e4e4e7; font-family: ui-monospace, monospace; }
    .history-metrics select { width: auto; padding: 0.25rem 0.375rem; font-size: 0.6875rem; border: 1px solid #e4e4e7; font-family: ui-monospace, monospace; }
    .perf-flop { color: #ef4444; }
    .perf-correct { color: #f59e0b; }
    .perf-carton { color: #22c55e; }
    .history-empty { padding: 3rem; text-align: center; color: #a1a1aa; font-size: 0.8125rem; border: 1px dashed #e4e4e7; }
  </style>
</head>
<body>
  <div class="container">
    <nav class="admin-nav">
      <a href="/admin/blog">Blog</a>
      <a href="/admin/linkedin" class="active">LinkedIn Studio</a>
    </nav>

    <h1>LinkedIn Studio</h1>
    <p class="subtitle">Génère tes posts LinkedIn + visuels brandés. Copie, colle, publie.</p>

    <!-- Main tabs -->
    <div class="main-tabs">
      <button class="main-tab active" data-panel="panel-post">Nouveau post</button>
      <button class="main-tab" data-panel="panel-veille">Veille hebdo</button>
      <button class="main-tab" data-panel="panel-blog">Depuis le blog</button>
      <button class="main-tab" data-panel="panel-history">Historique</button>
    </div>

    <!-- ==================== TAB 1: Nouveau post ==================== -->
    <div id="panel-post" class="tab-panel">
      <div id="step-input" class="card">
        <div class="card-header">01 — Ton sujet</div>
        <div class="field">
          <label for="input">Lien, idée, ou sujet</label>
          <textarea id="input" rows="3" placeholder="Ex: Colle un lien d'article, décris un sujet, partage une stat..."></textarea>
        </div>
        <div class="field">
          <label>Format du post</label>
          <div class="format-options">
            <div class="format-option">
              <input type="radio" name="format" id="fmt-analyse" value="analyse" checked />
              <label for="fmt-analyse">
                Analyse courte
                <span>Source + ce que j'en retiens</span>
              </label>
            </div>
            <div class="format-option">
              <input type="radio" name="format" id="fmt-opinion" value="opinion" />
              <label for="fmt-opinion">
                Prise de position
                <span>J'estime que... + arguments</span>
              </label>
            </div>
            <div class="format-option">
              <input type="radio" name="format" id="fmt-fait" value="fait" />
              <label for="fmt-fait">
                Fait marquant
                <span>Chiffre / stat + commentaire</span>
              </label>
            </div>
          </div>
        </div>
        <button id="btn-generate" class="btn btn-primary" style="width:100%">
          Générer le post
        </button>
        <div id="status-generate" class="status hidden"></div>
      </div>
    </div>

    <!-- ==================== TAB 2: Veille hebdo ==================== -->
    <div id="panel-veille" class="tab-panel hidden">
      <div class="card">
        <div class="card-header">Accumuler des actus</div>
        <p class="veille-counter">Pendant la semaine, ajoute des liens. Quand tu es prêt, génère ta veille hebdo.</p>
        <div class="row" style="margin-bottom: 1rem;">
          <div class="field" style="margin-bottom:0">
            <label for="veille-url">Lien de l'actu</label>
            <input type="text" id="veille-url" placeholder="https://..." />
          </div>
          <div class="field" style="margin-bottom:0">
            <label for="veille-title">Titre / description courte</label>
            <input type="text" id="veille-title" placeholder="De quoi ça parle ?" />
          </div>
        </div>
        <div class="field">
          <label for="veille-note">Note perso (optionnel)</label>
          <input type="text" id="veille-note" placeholder="Ton angle, ce qui t'a marqué..." />
        </div>
        <button id="btn-add-veille" class="btn btn-ghost btn-sm" style="width:100%">
          Ajouter à la veille
        </button>
      </div>

      <div class="card">
        <div class="card-header">Actus accumulées</div>
        <div id="veille-count" class="veille-counter"></div>
        <div id="veille-list"></div>
        <div class="actions" style="margin-top: 1rem;">
          <button id="btn-generate-veille" class="btn btn-primary" disabled>
            Générer la veille hebdo
          </button>
          <button id="btn-clear-veille" class="btn btn-danger btn-sm">
            Vider la liste
          </button>
        </div>
        <div id="status-veille" class="status hidden"></div>
      </div>
    </div>

    <!-- ==================== TAB 3: Depuis le blog ==================== -->
    <div id="panel-blog" class="tab-panel hidden">
      <div class="card">
        <div class="card-header">Décliner un article en post LinkedIn</div>
        <div class="field">
          <label>Format de déclinaison</label>
          <div class="format-options">
            <div class="format-option">
              <input type="radio" name="blog-format" id="bfmt-analyse" value="analyse" checked />
              <label for="bfmt-analyse">Analyse courte</label>
            </div>
            <div class="format-option">
              <input type="radio" name="blog-format" id="bfmt-opinion" value="opinion" />
              <label for="bfmt-opinion">Prise de position</label>
            </div>
            <div class="format-option">
              <input type="radio" name="blog-format" id="bfmt-fait" value="fait" />
              <label for="bfmt-fait">Fait marquant</label>
            </div>
          </div>
        </div>
        <div id="blog-list">
          {blogArticles.map(a => (
            <div class="blog-item" data-title={a.title} data-description={a.description} data-slug={a.slug} data-lang={a.lang}>
              <div class="blog-item-info">
                <div class="blog-item-title">{a.title}</div>
                <div class="blog-item-meta">
                  <span class="lang">{a.lang}</span> — {a.date} — {a.tags.join(', ')}
                </div>
              </div>
              <button class="btn btn-ghost btn-sm btn-repurpose">Décliner</button>
            </div>
          ))}
        </div>
        <div id="status-blog" class="status hidden"></div>
      </div>
    </div>

    <!-- ==================== TAB 4: Historique ==================== -->
    <div id="panel-history" class="tab-panel hidden">
      <div id="history-stats" class="history-stats"></div>
      <div class="card">
        <div class="card-header">Répartition des tags</div>
        <div id="history-tags" class="tag-cloud"></div>
      </div>
      <div class="card">
        <div class="card-header">Posts publiés</div>
        <div id="history-list"></div>
      </div>
    </div>

    <!-- ==================== SHARED: Edit + Visual + Preview + Export ==================== -->
    <div id="step-edit" class="hidden">
      <div class="edit-layout">
        <!-- Left: text -->
        <div>
          <div class="card">
            <div class="card-header">Post généré</div>
            <div class="field">
              <label for="post-text">Texte du post</label>
              <textarea id="post-text" rows="14" style="font-size: 0.8125rem;"></textarea>
            </div>
            <div class="actions" style="margin-top: 0;">
              <button id="btn-regenerate" class="btn btn-ghost">Régénérer</button>
              <button id="btn-feedback-toggle" class="btn btn-danger btn-sm">Pas mon style</button>
            </div>
            <div id="feedback-zone" class="feedback-zone hidden">
              <input type="text" id="feedback-input" placeholder="Ex: trop marketing, trop long, pas assez direct..." />
              <button id="btn-feedback-save" class="btn btn-sm btn-primary">Retenir</button>
            </div>
            <div id="feedback-prefs" class="feedback-prefs"></div>
          </div>
        </div>

        <!-- Right: visual -->
        <div>
          <div class="card">
            <div class="card-header">Visuel</div>
            <div class="field">
              <label for="headline">Titre du visuel</label>
              <input type="text" id="headline" placeholder="Titre court et percutant" />
            </div>
            <div class="field">
              <label for="vis-subtitle">Sous-titre (optionnel)</label>
              <input type="text" id="vis-subtitle" placeholder="Chiffre clé, source..." />
            </div>
            <div class="field">
              <label>Taille</label>
              <div class="size-options">
                <div class="size-option">
                  <input type="radio" name="size" id="size-square" value="1080x1080" checked />
                  <label for="size-square">1080x1080 Carré</label>
                </div>
                <div class="size-option">
                  <input type="radio" name="size" id="size-portrait" value="1080x1350" />
                  <label for="size-portrait">1080x1350 Portrait</label>
                </div>
                <div class="size-option">
                  <input type="radio" name="size" id="size-landscape" value="1200x630" />
                  <label for="size-landscape">1200x630 Paysage</label>
                </div>
              </div>
            </div>
            <button id="btn-visual" class="btn btn-primary" style="width:100%">
              Générer le visuel
            </button>
            <div id="status-visual" class="status hidden"></div>
            <div id="visual-container" class="visual-preview" style="margin-top: 1rem;">
              <span class="placeholder">Le visuel apparaîtra ici</span>
            </div>
          </div>
        </div>
      </div>

      <!-- LinkedIn Preview -->
      <div class="card">
        <div class="card-header">Aperçu LinkedIn</div>
        <div class="linkedin-mock">
          <div class="linkedin-mock-header">
            <img src="/images/pierre-touzet-sm.png" alt="" class="linkedin-mock-avatar" />
            <div class="linkedin-mock-meta">
              <span class="linkedin-mock-name">Pierre Touzet</span>
              <span class="linkedin-mock-title">Responsable national des programmes | Créateur de Gradly</span>
              <span class="linkedin-mock-time">Maintenant</span>
            </div>
          </div>
          <div id="preview-body" class="linkedin-mock-body linkedin-mock-truncated">
            Le texte de ton post apparaîtra ici...
          </div>
          <div id="preview-image" class="linkedin-mock-image hidden">
            <img id="preview-img" src="" alt="" />
          </div>
          <div class="linkedin-mock-actions">
            <span class="linkedin-mock-action">&#128077; J'aime</span>
            <span class="linkedin-mock-action">&#128172; Commenter</span>
            <span class="linkedin-mock-action">&#8634; Republier</span>
            <span class="linkedin-mock-action">&#9993; Envoyer</span>
          </div>
        </div>
      </div>

      <!-- Tags -->
      <div class="card">
        <div class="card-header">Tags du post</div>
        <div class="row" style="align-items:end">
          <input type="text" id="post-tag-input" placeholder="Ajouter un tag + Entrée" />
        </div>
        <div id="post-tags-list" class="tags-container"></div>
      </div>

      <!-- Export -->
      <div class="card">
        <div class="card-header">Exporter</div>
        <div class="export-actions">
          <button id="btn-copy" class="btn btn-accent">Copier le texte</button>
          <button id="btn-download" class="btn btn-primary" disabled>Télécharger le visuel</button>
          <button id="btn-save-history" class="btn btn-ghost">Sauver dans l'historique</button>
          <button id="btn-new" class="btn btn-ghost">Nouveau post</button>
        </div>
        <div id="status-save" class="status hidden"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    // ==================== STATE ====================
    let currentVisualBlob = null;
    let currentSize = '1080x1080';
    let currentFormat = 'analyse';
    let currentInput = '';
    let veilleItems = JSON.parse(localStorage.getItem('linkedin-veille') || '[]');
    let feedbackPrefs = JSON.parse(localStorage.getItem('linkedin-feedback') || '[]');
    let postHistory = JSON.parse(localStorage.getItem('linkedin-history') || '[]');
    let postTags = [];

    // ==================== ELEMENTS ====================
    const $input = document.getElementById('input');
    const $postText = document.getElementById('post-text');
    const $headline = document.getElementById('headline');
    const $visSubtitle = document.getElementById('vis-subtitle');
    const $visualContainer = document.getElementById('visual-container');
    const $previewBody = document.getElementById('preview-body');
    const $previewImage = document.getElementById('preview-image');
    const $previewImg = document.getElementById('preview-img');

    const $stepEdit = document.getElementById('step-edit');

    const $btnGenerate = document.getElementById('btn-generate');
    const $btnRegenerate = document.getElementById('btn-regenerate');
    const $btnVisual = document.getElementById('btn-visual');
    const $btnCopy = document.getElementById('btn-copy');
    const $btnDownload = document.getElementById('btn-download');
    const $btnNew = document.getElementById('btn-new');

    const $statusGenerate = document.getElementById('status-generate');
    const $statusVisual = document.getElementById('status-visual');

    // Veille elements
    const $veilleUrl = document.getElementById('veille-url');
    const $veilleTitle = document.getElementById('veille-title');
    const $veilleNote = document.getElementById('veille-note');
    const $veilleList = document.getElementById('veille-list');
    const $veilleCount = document.getElementById('veille-count');
    const $btnAddVeille = document.getElementById('btn-add-veille');
    const $btnGenerateVeille = document.getElementById('btn-generate-veille');
    const $btnClearVeille = document.getElementById('btn-clear-veille');
    const $statusVeille = document.getElementById('status-veille');
    const $statusBlog = document.getElementById('status-blog');
    const $statusSave = document.getElementById('status-save');

    // Feedback elements
    const $btnFeedbackToggle = document.getElementById('btn-feedback-toggle');
    const $feedbackZone = document.getElementById('feedback-zone');
    const $feedbackInput = document.getElementById('feedback-input');
    const $btnFeedbackSave = document.getElementById('btn-feedback-save');
    const $feedbackPrefs = document.getElementById('feedback-prefs');

    // Tags elements
    const $postTagInput = document.getElementById('post-tag-input');
    const $postTagsList = document.getElementById('post-tags-list');

    // History elements
    const $historyStats = document.getElementById('history-stats');
    const $historyTags = document.getElementById('history-tags');
    const $historyList = document.getElementById('history-list');
    const $btnSaveHistory = document.getElementById('btn-save-history');

    // ==================== TABS ====================
    document.querySelectorAll('.main-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.main-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.panel).classList.remove('hidden');
      });
    });

    // ==================== HELPERS ====================
    function getFormat() {
      return document.querySelector('input[name="format"]:checked')?.value || 'analyse';
    }
    function getBlogFormat() {
      return document.querySelector('input[name="blog-format"]:checked')?.value || 'analyse';
    }
    function getSize() {
      return document.querySelector('input[name="size"]:checked')?.value || '1080x1080';
    }

    function updatePreview() {
      const text = $postText.value || 'Le texte de ton post apparaîtra ici...';
      $previewBody.textContent = text;
      if (text.length > 250) {
        $previewBody.classList.add('linkedin-mock-truncated');
      } else {
        $previewBody.classList.remove('linkedin-mock-truncated');
      }
    }
    $postText?.addEventListener('input', updatePreview);

    function showEdit(data) {
      $postText.value = data.text || '';
      $headline.value = data.headline || '';
      $visSubtitle.value = data.subtitle || '';
      updatePreview();
      // Reset visual
      currentVisualBlob = null;
      $visualContainer.innerHTML = '<span class="placeholder">Le visuel apparaîtra ici</span>';
      $previewImage.classList.add('hidden');
      $btnDownload.disabled = true;
      // Show
      $stepEdit.classList.remove('hidden');
      $stepEdit.scrollIntoView({ behavior: 'smooth' });
    }

    function resetAll() {
      $input.value = '';
      $postText.value = '';
      $headline.value = '';
      $visSubtitle.value = '';
      currentVisualBlob = null;
      currentInput = '';
      postTags = [];
      renderPostTags();
      $visualContainer.innerHTML = '<span class="placeholder">Le visuel apparaîtra ici</span>';
      $previewBody.textContent = 'Le texte de ton post apparaîtra ici...';
      $previewImage.classList.add('hidden');
      $btnDownload.disabled = true;
      $stepEdit.classList.add('hidden');
      $feedbackZone.classList.add('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ==================== GENERATE POST (shared) ====================
    async function callGenerate(input, format, statusEl, btnEl) {
      if (!input) return null;
      currentInput = input;
      currentFormat = format;

      if (btnEl) {
        btnEl.disabled = true;
        btnEl.innerHTML = '<span class="spinner"></span> Génération...';
      }
      if (statusEl) {
        statusEl.classList.remove('hidden', 'error');
        statusEl.textContent = 'Claude rédige ton post LinkedIn...';
      }

      try {
        const res = await fetch('/api/generate-linkedin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ input, format, preferences: feedbackPrefs }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.raw ? data.error + ' — ' + data.raw : (data.error || 'Erreur'));
        if (statusEl) statusEl.classList.add('hidden');
        return data;
      } catch (err) {
        if (statusEl) {
          statusEl.classList.add('error');
          statusEl.textContent = 'Erreur : ' + err.message;
        }
        return null;
      } finally {
        if (btnEl) {
          btnEl.disabled = false;
          btnEl.textContent = btnEl.dataset.label || 'Générer le post';
        }
      }
    }

    // ==================== TAB 1: Nouveau post ====================
    $btnGenerate.dataset.label = 'Générer le post';
    $btnGenerate.addEventListener('click', async () => {
      const data = await callGenerate($input.value.trim(), getFormat(), $statusGenerate, $btnGenerate);
      if (data) showEdit(data);
    });

    $btnRegenerate.addEventListener('click', async () => {
      const data = await callGenerate(currentInput, currentFormat, $statusGenerate, null);
      if (data) showEdit(data);
    });

    // ==================== TAB 2: Veille hebdo ====================
    function saveVeille() {
      localStorage.setItem('linkedin-veille', JSON.stringify(veilleItems));
    }

    function renderVeille() {
      $veilleCount.textContent = veilleItems.length + ' actu' + (veilleItems.length > 1 ? 's' : '') + ' dans la pile';
      $btnGenerateVeille.disabled = veilleItems.length < 1;

      if (veilleItems.length === 0) {
        $veilleList.innerHTML = '<div class="veille-empty">Aucune actu pour le moment. Ajoute des liens ci-dessus.</div>';
        return;
      }

      $veilleList.innerHTML = veilleItems.map((item, i) => `
        <div class="veille-item">
          <div class="veille-item-content">
            <div class="veille-item-title">${escHtml(item.title)}</div>
            ${item.url ? '<div class="veille-item-url">' + escHtml(item.url) + '</div>' : ''}
            ${item.note ? '<div class="veille-item-note">' + escHtml(item.note) + '</div>' : ''}
            <div class="veille-item-date">${item.date}</div>
          </div>
          <button class="btn btn-danger btn-sm" onclick="removeVeille(${i})">Retirer</button>
        </div>
      `).join('');
    }

    function escHtml(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    window.removeVeille = function(i) {
      veilleItems.splice(i, 1);
      saveVeille();
      renderVeille();
    };

    $btnAddVeille.addEventListener('click', () => {
      const title = $veilleTitle.value.trim();
      if (!title) return;
      veilleItems.push({
        url: $veilleUrl.value.trim(),
        title,
        note: $veilleNote.value.trim(),
        date: new Date().toISOString().slice(0, 10),
      });
      saveVeille();
      renderVeille();
      $veilleUrl.value = '';
      $veilleTitle.value = '';
      $veilleNote.value = '';
    });

    $btnClearVeille.addEventListener('click', () => {
      if (veilleItems.length && confirm('Vider toute la liste de veille ?')) {
        veilleItems = [];
        saveVeille();
        renderVeille();
      }
    });

    $btnGenerateVeille.dataset.label = 'Générer la veille hebdo';
    $btnGenerateVeille.addEventListener('click', async () => {
      // Build input from accumulated items
      const itemsText = veilleItems.map((item, i) =>
        `Actu ${i + 1}:\n` +
        `Titre: ${item.title}\n` +
        (item.url ? `Source: ${item.url}\n` : '') +
        (item.note ? `Note de Pierre: ${item.note}\n` : '')
      ).join('\n');

      const input = `Voici les actus accumulées cette semaine pour la veille hebdo :\n\n${itemsText}`;

      const data = await callGenerate(input, 'veille', $statusVeille, $btnGenerateVeille);
      if (data) {
        currentFormat = 'veille';
        showEdit(data);
      }
    });

    renderVeille();

    // ==================== TAB 3: Depuis le blog ====================
    document.querySelectorAll('.btn-repurpose').forEach(btn => {
      btn.addEventListener('click', async () => {
        const item = btn.closest('.blog-item');
        const title = item.dataset.title;
        const description = item.dataset.description;
        const slug = item.dataset.slug;
        const lang = item.dataset.lang;
        const format = getBlogFormat();
        const blogUrl = `https://www.pierretouzet.fr/${lang}/blog/${slug}`;

        const input = `Décline cet article de blog en post LinkedIn :\n\nTitre : ${title}\nDescription : ${description}\nURL : ${blogUrl}\n\nLe post doit donner envie de lire l'article complet sans tout révéler. Inclus le lien vers l'article.`;

        btn.disabled = true;
        btn.textContent = '...';
        $statusBlog.classList.remove('hidden', 'error');
        $statusBlog.textContent = 'Génération du post depuis l\'article...';

        const data = await callGenerate(input, format, $statusBlog, null);
        btn.disabled = false;
        btn.textContent = 'Décliner';

        if (data) {
          currentFormat = format;
          showEdit(data);
        }
      });
    });

    // ==================== VISUAL GENERATION ====================
    $btnVisual.addEventListener('click', async () => {
      const headline = $headline.value.trim();
      const subtitle = $visSubtitle.value.trim();
      const format = currentFormat;
      const size = getSize();
      if (!headline) return;

      $btnVisual.disabled = true;
      $btnVisual.innerHTML = '<span class="spinner"></span> Génération...';
      $statusVisual.classList.remove('hidden', 'error');
      $statusVisual.textContent = 'Création du visuel...';

      try {
        const res = await fetch('/api/generate-linkedin-visual', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ headline, subtitle, format, size }),
        });

        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || 'Erreur');
        }

        const blob = await res.blob();
        currentVisualBlob = blob;
        currentSize = size;

        const url = URL.createObjectURL(blob);
        $visualContainer.innerHTML = '<img src="' + url + '" alt="Visuel LinkedIn" />';

        $previewImg.src = url;
        $previewImage.classList.remove('hidden');

        $btnDownload.disabled = false;
        $statusVisual.classList.add('hidden');
      } catch (err) {
        $statusVisual.classList.add('error');
        $statusVisual.textContent = 'Erreur : ' + err.message;
      } finally {
        $btnVisual.disabled = false;
        $btnVisual.textContent = 'Générer le visuel';
      }
    });

    // ==================== EXPORT ====================
    $btnCopy.addEventListener('click', async () => {
      const text = $postText.value.trim();
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        $btnCopy.textContent = 'Copié !';
        $btnCopy.classList.add('btn-copy-ok');
        $btnCopy.classList.remove('btn-accent');
        setTimeout(() => {
          $btnCopy.textContent = 'Copier le texte';
          $btnCopy.classList.remove('btn-copy-ok');
          $btnCopy.classList.add('btn-accent');
        }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        $btnCopy.textContent = 'Copié !';
        setTimeout(() => { $btnCopy.textContent = 'Copier le texte'; }, 2000);
      }
    });

    $btnDownload.addEventListener('click', () => {
      if (!currentVisualBlob) return;
      const url = URL.createObjectURL(currentVisualBlob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'linkedin-' + currentFormat + '-' + currentSize + '.png';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    });

    $btnNew.addEventListener('click', resetAll);

    // ==================== FEEDBACK LOOP ====================
    function saveFeedback() {
      localStorage.setItem('linkedin-feedback', JSON.stringify(feedbackPrefs));
    }

    function renderFeedback() {
      if (feedbackPrefs.length === 0) {
        $feedbackPrefs.innerHTML = '';
        return;
      }
      $feedbackPrefs.innerHTML = feedbackPrefs.map((p, i) =>
        '<span class="feedback-pref">' + escHtml(p) + '<button onclick="removeFeedback(' + i + ')">×</button></span>'
      ).join('');
    }

    window.removeFeedback = function(i) {
      feedbackPrefs.splice(i, 1);
      saveFeedback();
      renderFeedback();
    };

    $btnFeedbackToggle.addEventListener('click', () => {
      $feedbackZone.classList.toggle('hidden');
      if (!$feedbackZone.classList.contains('hidden')) $feedbackInput.focus();
    });

    $btnFeedbackSave.addEventListener('click', () => {
      const val = $feedbackInput.value.trim();
      if (!val) return;
      feedbackPrefs.push(val);
      saveFeedback();
      renderFeedback();
      $feedbackInput.value = '';
      $feedbackZone.classList.add('hidden');
      // Auto-regenerate with new preferences
      if (currentInput) {
        callGenerate(currentInput, currentFormat, $statusGenerate, null).then(data => {
          if (data) showEdit(data);
        });
      }
    });

    renderFeedback();

    // ==================== POST TAGS ====================
    function renderPostTags() {
      $postTagsList.innerHTML = postTags.map((t, i) =>
        '<span class="tag">' + escHtml(t) + '<button onclick="removePostTag(' + i + ')">×</button></span>'
      ).join('');
    }

    window.removePostTag = function(i) {
      postTags.splice(i, 1);
      renderPostTags();
    };

    $postTagInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const val = $postTagInput.value.trim();
        if (val && !postTags.includes(val)) {
          postTags.push(val);
          renderPostTags();
        }
        $postTagInput.value = '';
      }
    });

    // ==================== SAVE TO HISTORY ====================
    function saveHistory() {
      localStorage.setItem('linkedin-history', JSON.stringify(postHistory));
    }

    $btnSaveHistory.addEventListener('click', () => {
      const text = $postText.value.trim();
      const headline = $headline.value.trim();
      if (!text) return;

      const entry = {
        id: Date.now(),
        date: new Date().toISOString().slice(0, 10),
        format: currentFormat,
        headline: headline || text.slice(0, 60),
        excerpt: text.slice(0, 120),
        tags: [...postTags],
        reactions: 0,
        comments: 0,
        perf: '',
      };

      postHistory.unshift(entry);
      saveHistory();

      $statusSave.classList.remove('hidden', 'error');
      $statusSave.classList.add('success');
      $statusSave.textContent = 'Post sauvé dans l\'historique';
      setTimeout(() => $statusSave.classList.add('hidden'), 2000);
    });

    // ==================== HISTORY & METRICS ====================
    const MONTHS_FR = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

    function renderHistory() {
      // Stats
      const total = postHistory.length;
      const thisMonth = postHistory.filter(p => p.date.slice(0, 7) === new Date().toISOString().slice(0, 7)).length;
      const cartons = postHistory.filter(p => p.perf === 'carton').length;
      const formatCounts = {};
      postHistory.forEach(p => { formatCounts[p.format] = (formatCounts[p.format] || 0) + 1; });
      const topFormat = Object.entries(formatCounts).sort((a, b) => b[1] - a[1])[0];

      $historyStats.innerHTML = `
        <div class="stat-card"><div class="stat-value">${total}</div><div class="stat-label">Posts total</div></div>
        <div class="stat-card"><div class="stat-value">${thisMonth}</div><div class="stat-label">Ce mois</div></div>
        <div class="stat-card"><div class="stat-value">${cartons}</div><div class="stat-label">Cartons</div></div>
        <div class="stat-card"><div class="stat-value">${topFormat ? topFormat[0] : '-'}</div><div class="stat-label">Format favori</div></div>
      `;

      // Tag cloud
      const tagCounts = {};
      postHistory.forEach(p => (p.tags || []).forEach(t => { tagCounts[t] = (tagCounts[t] || 0) + 1; }));
      const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
      $historyTags.innerHTML = sortedTags.length
        ? sortedTags.map(([tag, count]) => '<span class="tag-cloud-item">' + escHtml(tag) + ' (' + count + ')</span>').join('')
        : '<span style="color:#a1a1aa;font-size:0.8125rem">Aucun tag pour le moment</span>';

      // Posts list grouped by month
      if (postHistory.length === 0) {
        $historyList.innerHTML = '<div class="history-empty">Aucun post dans l\'historique. Sauve tes posts depuis la section export.</div>';
        return;
      }

      let html = '';
      let lastMonth = '';
      postHistory.forEach((p, i) => {
        const month = p.date.slice(0, 7);
        if (month !== lastMonth) {
          const [y, m] = month.split('-');
          html += '<div class="history-month">' + MONTHS_FR[parseInt(m) - 1] + ' ' + y + '</div>';
          lastMonth = month;
        }
        const perfClass = p.perf === 'carton' ? 'perf-carton' : p.perf === 'flop' ? 'perf-flop' : p.perf === 'correct' ? 'perf-correct' : '';
        html += `
          <div class="history-item" data-index="${i}">
            <div class="history-item-content">
              <div class="history-item-headline">${escHtml(p.headline)}</div>
              <div class="history-item-excerpt">${escHtml(p.excerpt)}</div>
              <div class="history-item-meta">
                <span class="history-item-format">${escHtml(p.format)}</span>
                <span>${p.date}</span>
                ${(p.tags || []).map(t => '<span class="tag-cloud-item">' + escHtml(t) + '</span>').join('')}
              </div>
            </div>
            <div class="history-metrics">
              <input type="number" min="0" value="${p.reactions || 0}" placeholder="Likes" title="Réactions" onchange="updateMetric(${i},'reactions',this.value)" />
              <input type="number" min="0" value="${p.comments || 0}" placeholder="Com." title="Commentaires" onchange="updateMetric(${i},'comments',this.value)" />
              <select title="Performance" class="${perfClass}" onchange="updateMetric(${i},'perf',this.value)">
                <option value="">-</option>
                <option value="flop" ${p.perf === 'flop' ? 'selected' : ''}>Flop</option>
                <option value="correct" ${p.perf === 'correct' ? 'selected' : ''}>Correct</option>
                <option value="carton" ${p.perf === 'carton' ? 'selected' : ''}>Carton</option>
              </select>
              <button class="btn btn-danger btn-sm" onclick="removeHistory(${i})" title="Supprimer">×</button>
            </div>
          </div>
        `;
      });
      $historyList.innerHTML = html;
    }

    window.updateMetric = function(i, field, value) {
      if (!postHistory[i]) return;
      postHistory[i][field] = field === 'perf' ? value : parseInt(value) || 0;
      saveHistory();
      renderHistory();
    };

    window.removeHistory = function(i) {
      postHistory.splice(i, 1);
      saveHistory();
      renderHistory();
    };

    // Render history on tab switch
    document.querySelector('[data-panel="panel-history"]').addEventListener('click', renderHistory);
    renderHistory();
  </script>
</body>
</html>
