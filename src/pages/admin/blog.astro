---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Nouvel article — Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Inter, system-ui, sans-serif; background: #fafafa; color: #18181b; }
    .container { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
    h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; }
    .subtitle { font-size: 0.8125rem; color: #71717a; margin-bottom: 2rem; font-family: ui-monospace, monospace; }

    /* Form elements */
    label { display: block; font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: #71717a; margin-bottom: 0.375rem; font-family: ui-monospace, monospace; }
    input, select, textarea { width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e4e4e7; background: white; font-size: 0.875rem; font-family: inherit; outline: none; transition: border-color 0.15s; }
    input:focus, select:focus, textarea:focus { border-color: #4f46e5; }
    textarea { resize: vertical; line-height: 1.6; }

    .field { margin-bottom: 1.25rem; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; font-size: 0.8125rem; font-weight: 500; font-family: inherit; border: none; cursor: pointer; transition: all 0.15s; }
    .btn-primary { background: #18181b; color: white; }
    .btn-primary:hover:not(:disabled) { background: #4f46e5; }
    .btn-accent { background: #4f46e5; color: white; }
    .btn-accent:hover:not(:disabled) { background: #4338ca; }
    .btn-ghost { background: transparent; color: #71717a; border: 1px solid #e4e4e7; }
    .btn-ghost:hover:not(:disabled) { color: #18181b; border-color: #a1a1aa; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; }

    /* Sections */
    .card { background: white; border: 1px solid #e4e4e7; padding: 1.5rem; margin-bottom: 1.5rem; }
    .card-header { font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; color: #4f46e5; margin-bottom: 1rem; font-family: ui-monospace, monospace; }
    .divider { height: 1px; background: #e4e4e7; margin: 2rem 0; }

    /* Preview */
    .preview { background: white; border: 1px solid #e4e4e7; padding: 2rem; font-size: 0.9375rem; line-height: 1.7; }
    .preview h2 { font-size: 1.25rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
    .preview h3 { font-size: 1.0625rem; font-weight: 600; margin: 1.25rem 0 0.375rem; }
    .preview p { margin-bottom: 0.75rem; color: #3f3f46; }
    .preview ul, .preview ol { margin-bottom: 0.75rem; padding-left: 1.5rem; color: #3f3f46; }
    .preview li { margin-bottom: 0.25rem; }
    .preview strong { color: #18181b; }
    .preview blockquote { border-left: 3px solid #4f46e5; padding-left: 1rem; margin: 1rem 0; color: #71717a; font-style: italic; }

    /* Tags input */
    .tags-container { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.375rem; }
    .tag { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.25rem 0.625rem; background: rgba(79, 70, 229, 0.08); color: #4f46e5; font-family: ui-monospace, monospace; }
    .tag button { background: none; border: none; color: #4f46e5; cursor: pointer; font-size: 0.875rem; line-height: 1; padding: 0 0.125rem; }

    /* Tabs */
    .tabs { display: flex; gap: 0; margin-bottom: -1px; position: relative; z-index: 1; }
    .tab { padding: 0.5rem 1rem; font-size: 0.75rem; font-family: ui-monospace, monospace; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; border: 1px solid transparent; background: transparent; color: #71717a; }
    .tab.active { background: white; border-color: #e4e4e7; border-bottom-color: white; color: #18181b; }

    /* Status */
    .status { font-size: 0.75rem; color: #71717a; font-family: ui-monospace, monospace; padding: 0.75rem 0; }
    .status.error { color: #ef4444; }
    .status.success { color: #22c55e; }

    /* Spinner */
    .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-radius: 50%; border-top-color: white; animation: spin 0.6s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .hidden { display: none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Nouvel article</h1>
    <p class="subtitle">Assistant IA — Décris ton idée, il rédige pour toi.</p>

    <!-- Step 1: Idea -->
    <div id="step-idea" class="card">
      <div class="card-header">01 — Ton idée</div>
      <div class="field">
        <label for="idea">De quoi veux-tu parler ?</label>
        <textarea id="idea" rows="4" placeholder="Ex: Je voudrais parler de mon expérience avec l'adoption du LMS dans les écoles, comment j'ai convaincu les formateurs réticents..."></textarea>
      </div>
      <div class="row">
        <div class="field">
          <label for="lang">Langue</label>
          <select id="lang">
            <option value="fr" selected>Français</option>
            <option value="en">English</option>
          </select>
        </div>
        <div class="field">
          <label>&nbsp;</label>
          <button id="btn-generate" class="btn btn-primary" style="width:100%">
            Générer l'article
          </button>
        </div>
      </div>
      <div id="status-generate" class="status hidden"></div>
    </div>

    <!-- Step 2: Edit -->
    <div id="step-edit" class="hidden">
      <div class="card">
        <div class="card-header">02 — Article généré</div>
        <div class="row">
          <div class="field">
            <label for="title">Titre</label>
            <input type="text" id="title" />
          </div>
          <div class="field">
            <label for="description">Description SEO</label>
            <input type="text" id="description" />
          </div>
        </div>
        <div class="field">
          <label>Tags</label>
          <div class="row" style="align-items:end">
            <input type="text" id="tag-input" placeholder="Ajouter un tag + Entrée" />
          </div>
          <div id="tags-list" class="tags-container"></div>
        </div>
      </div>

      <div class="tabs">
        <button class="tab active" data-tab="editor">Éditeur</button>
        <button class="tab" data-tab="preview">Preview</button>
      </div>
      <div id="tab-editor">
        <textarea id="content" rows="24" style="font-family: ui-monospace, monospace; font-size: 0.8125rem; border-top: none;"></textarea>
      </div>
      <div id="tab-preview" class="preview hidden"></div>

      <div class="actions">
        <button id="btn-regenerate" class="btn btn-ghost">Régénérer</button>
        <button id="btn-publish" class="btn btn-accent">
          Publier sur le site
        </button>
      </div>
      <div id="status-publish" class="status hidden"></div>
    </div>

    <!-- Step 3: Published -->
    <div id="step-done" class="hidden">
      <div class="card" style="text-align:center; padding: 3rem;">
        <div style="font-size: 2rem; margin-bottom: 1rem;">✓</div>
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">Article publié</h2>
        <p id="published-info" style="font-size: 0.875rem; color: #71717a; margin-bottom: 1.5rem;"></p>
        <div class="actions" style="justify-content: center;">
          <a id="published-link" href="#" class="btn btn-primary" target="_blank">Voir l'article</a>
          <button id="btn-linkedin" class="btn btn-accent">Décliner en post LinkedIn</button>
          <button id="btn-new" class="btn btn-ghost">Nouvel article</button>
        </div>
      </div>

      <!-- LinkedIn auto-pipeline -->
      <div id="linkedin-pipeline" class="hidden">
        <div class="card">
          <div class="card-header">Post LinkedIn généré</div>
          <div class="field">
            <label>Format</label>
            <div class="row-3" style="margin-bottom:0.75rem">
              <label style="display:inline-flex;align-items:center;gap:0.375rem;text-transform:none;letter-spacing:normal;font-size:0.8125rem;cursor:pointer">
                <input type="radio" name="li-format" value="analyse" checked style="width:auto" /> Analyse
              </label>
              <label style="display:inline-flex;align-items:center;gap:0.375rem;text-transform:none;letter-spacing:normal;font-size:0.8125rem;cursor:pointer">
                <input type="radio" name="li-format" value="opinion" style="width:auto" /> Opinion
              </label>
              <label style="display:inline-flex;align-items:center;gap:0.375rem;text-transform:none;letter-spacing:normal;font-size:0.8125rem;cursor:pointer">
                <input type="radio" name="li-format" value="fait" style="width:auto" /> Fait marquant
              </label>
            </div>
          </div>
          <div id="status-linkedin" class="status">Choisis un format et clique sur Générer.</div>
          <button id="btn-gen-linkedin" class="btn btn-primary" style="width:100%;margin-top:0.75rem">Générer le post LinkedIn</button>
          <div id="linkedin-result" class="hidden" style="margin-top:1rem">
            <div class="field">
              <label for="li-text">Texte du post</label>
              <textarea id="li-text" rows="10" style="font-size:0.8125rem"></textarea>
            </div>
            <div class="actions">
              <button id="btn-copy-li" class="btn btn-accent">Copier le texte</button>
              <a href="/admin/linkedin" class="btn btn-ghost">Ouvrir LinkedIn Studio</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // State
    let tags = [];

    // Elements
    const $idea = document.getElementById('idea');
    const $lang = document.getElementById('lang');
    const $title = document.getElementById('title');
    const $description = document.getElementById('description');
    const $content = document.getElementById('content');
    const $tagInput = document.getElementById('tag-input');
    const $tagsList = document.getElementById('tags-list');
    const $preview = document.getElementById('tab-preview');

    const $stepIdea = document.getElementById('step-idea');
    const $stepEdit = document.getElementById('step-edit');
    const $stepDone = document.getElementById('step-done');

    const $btnGenerate = document.getElementById('btn-generate');
    const $btnRegenerate = document.getElementById('btn-regenerate');
    const $btnPublish = document.getElementById('btn-publish');
    const $btnNew = document.getElementById('btn-new');

    const $statusGenerate = document.getElementById('status-generate');
    const $statusPublish = document.getElementById('status-publish');

    // Tags
    function renderTags() {
      $tagsList.innerHTML = tags.map((t, i) =>
        `<span class="tag">${t}<button onclick="removeTag(${i})">&times;</button></span>`
      ).join('');
    }
    window.removeTag = function(i) { tags.splice(i, 1); renderTags(); };

    $tagInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const val = $tagInput.value.trim();
        if (val && !tags.includes(val)) {
          tags.push(val);
          renderTags();
        }
        $tagInput.value = '';
      }
    });

    // Tabs
    document.querySelectorAll('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const target = tab.dataset.tab;
        document.getElementById('tab-editor').classList.toggle('hidden', target !== 'editor');
        document.getElementById('tab-preview').classList.toggle('hidden', target !== 'preview');
        if (target === 'preview') renderPreview();
      });
    });

    function renderPreview() {
      // Simple Markdown to HTML
      let md = $content.value;
      md = md.replace(/^### (.+)$/gm, '<h3>$1</h3>');
      md = md.replace(/^## (.+)$/gm, '<h2>$1</h2>');
      md = md.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      md = md.replace(/\*(.+?)\*/g, '<em>$1</em>');
      md = md.replace(/^- (.+)$/gm, '<li>$1</li>');
      md = md.replace(/(<li>.*<\/li>\n?)+/g, (m) => '<ul>' + m + '</ul>');
      md = md.replace(/^> (.+)$/gm, '<blockquote><p>$1</p></blockquote>');
      md = md.replace(/\n\n/g, '</p><p>');
      md = '<p>' + md + '</p>';
      md = md.replace(/<p><h/g, '<h').replace(/<\/h([23])><\/p>/g, '</h$1>');
      md = md.replace(/<p><ul>/g, '<ul>').replace(/<\/ul><\/p>/g, '</ul>');
      md = md.replace(/<p><blockquote>/g, '<blockquote>').replace(/<\/blockquote><\/p>/g, '</blockquote>');
      md = md.replace(/<p>\s*<\/p>/g, '');
      $preview.innerHTML = md;
    }

    // Generate
    async function generate() {
      const idea = $idea.value.trim();
      const lang = $lang.value;
      if (!idea) return;

      $btnGenerate.disabled = true;
      $btnGenerate.innerHTML = '<span class="spinner"></span> Génération en cours...';
      $statusGenerate.classList.remove('hidden', 'error');
      $statusGenerate.textContent = 'Claude rédige ton article...';

      try {
        const res = await fetch('/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ idea, lang }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur');

        $title.value = data.title || '';
        $description.value = data.description || '';
        $content.value = data.content || '';
        tags = data.tags || [];
        renderTags();

        $stepEdit.classList.remove('hidden');
        $statusGenerate.classList.add('hidden');
        $stepEdit.scrollIntoView({ behavior: 'smooth' });
      } catch (err) {
        $statusGenerate.classList.add('error');
        $statusGenerate.textContent = 'Erreur : ' + err.message;
      } finally {
        $btnGenerate.disabled = false;
        $btnGenerate.textContent = 'Générer l\'article';
      }
    }

    $btnGenerate.addEventListener('click', generate);
    $btnRegenerate.addEventListener('click', generate);

    // Publish
    $btnPublish.addEventListener('click', async () => {
      const title = $title.value.trim();
      const content = $content.value.trim();
      if (!title || !content) return;

      $btnPublish.disabled = true;
      $btnPublish.innerHTML = '<span class="spinner"></span> Publication...';
      $statusPublish.classList.remove('hidden', 'error', 'success');
      $statusPublish.textContent = 'Commit sur GitHub en cours...';

      try {
        const res = await fetch('/api/publish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({
            title,
            description: $description.value.trim(),
            tags,
            content,
            lang: $lang.value,
          }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur');

        const siteUrl = 'https://www.pierretouzet.fr';
        document.getElementById('published-link').href = siteUrl + data.url;
        document.getElementById('published-info').textContent =
          `L'article sera en ligne dans ~1 minute après le rebuild Vercel.`;

        $stepEdit.classList.add('hidden');
        $stepDone.classList.remove('hidden');
        $statusPublish.classList.add('hidden');
      } catch (err) {
        $statusPublish.classList.add('error');
        $statusPublish.textContent = 'Erreur : ' + err.message;
      } finally {
        $btnPublish.disabled = false;
        $btnPublish.textContent = 'Publier sur le site';
      }
    });

    // New article
    $btnNew.addEventListener('click', () => {
      $idea.value = '';
      $title.value = '';
      $description.value = '';
      $content.value = '';
      tags = [];
      renderTags();
      $stepEdit.classList.add('hidden');
      $stepDone.classList.add('hidden');
      document.getElementById('linkedin-pipeline').classList.add('hidden');
      document.getElementById('linkedin-result').classList.add('hidden');
      $stepIdea.scrollIntoView({ behavior: 'smooth' });
    });

    // ==================== LINKEDIN AUTO-PIPELINE ====================
    const $btnLinkedin = document.getElementById('btn-linkedin');
    const $linkedinPipeline = document.getElementById('linkedin-pipeline');
    const $btnGenLinkedin = document.getElementById('btn-gen-linkedin');
    const $statusLinkedin = document.getElementById('status-linkedin');
    const $linkedinResult = document.getElementById('linkedin-result');
    const $liText = document.getElementById('li-text');
    const $btnCopyLi = document.getElementById('btn-copy-li');

    $btnLinkedin.addEventListener('click', () => {
      $linkedinPipeline.classList.remove('hidden');
      $linkedinPipeline.scrollIntoView({ behavior: 'smooth' });
    });

    $btnGenLinkedin.addEventListener('click', async () => {
      const title = $title.value.trim();
      const description = $description.value.trim();
      const liFormat = document.querySelector('input[name="li-format"]:checked')?.value || 'analyse';
      const blogUrl = document.getElementById('published-link').href;

      const input = 'Décline cet article de blog en post LinkedIn :\n\nTitre : ' + title +
        '\nDescription : ' + description +
        '\nURL : ' + blogUrl +
        '\n\nLe post doit donner envie de lire l\'article complet sans tout révéler. Inclus le lien vers l\'article.';

      $btnGenLinkedin.disabled = true;
      $btnGenLinkedin.innerHTML = '<span class="spinner"></span> Génération...';
      $statusLinkedin.classList.remove('error', 'success');
      $statusLinkedin.textContent = 'Claude rédige le post LinkedIn...';

      try {
        const feedbackPrefs = JSON.parse(localStorage.getItem('linkedin-feedback') || '[]');
        const res = await fetch('/api/generate-linkedin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ input, format: liFormat, preferences: feedbackPrefs }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Erreur');

        $liText.value = data.text || '';
        $linkedinResult.classList.remove('hidden');
        $statusLinkedin.classList.add('success');
        $statusLinkedin.textContent = 'Post généré !';
      } catch (err) {
        $statusLinkedin.classList.add('error');
        $statusLinkedin.textContent = 'Erreur : ' + err.message;
      } finally {
        $btnGenLinkedin.disabled = false;
        $btnGenLinkedin.textContent = 'Générer le post LinkedIn';
      }
    });

    $btnCopyLi.addEventListener('click', async () => {
      const text = $liText.value.trim();
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        $btnCopyLi.textContent = 'Copié !';
        setTimeout(() => { $btnCopyLi.textContent = 'Copier le texte'; }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        $btnCopyLi.textContent = 'Copié !';
        setTimeout(() => { $btnCopyLi.textContent = 'Copier le texte'; }, 2000);
      }
    });
  </script>
</body>
</html>
