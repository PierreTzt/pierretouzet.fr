---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getData } from '../../../i18n/utils';
import type { Project } from '../../../data/types';

const lang = 'fr';
const data = getData(lang);

export function getStaticPaths() {
  const data = getData('fr');
  return data.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/project-*.png', { eager: true });
const imageSlug = project.slug === 'innovation-pedagogique' ? 'innovation' : project.slug;
const projectImage = images[`/src/assets/images/project-${imageSlug}.png`]?.default;
---

<BaseLayout
  title={`${project.title} — ${data.personal.name}`}
  description={project.shortDescription}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: '/fr/' },
    { name: data.ui.nav.projects, url: '/fr/projets/' },
    { name: project.title, url: `/fr/projets/${project.slug}/` },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <a
        href="/fr/projets/"
        class="scroll-reveal group mono-label hover:text-accent-500 transition-colors duration-200 inline-flex items-center gap-2 mb-12"
      >
        <svg class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        {data.ui.project.backToProjects}
      </a>

      <div class="scroll-reveal mb-12">
        <span class="mono-label mb-4 block">{data.ui.project.label}</span>
        <h1 class="font-display text-heading text-zinc-900 dark:text-zinc-50 font-bold mb-4">
          {project.title}
        </h1>
        <div class="h-[1px] bg-gradient-to-r from-accent-500 via-electric-500 to-transparent mt-6"></div>
      </div>

      <!-- Project visual -->
      <div class="scroll-reveal aspect-video border border-zinc-200 dark:border-zinc-800 mb-12 overflow-hidden" style="transition-delay: 100ms">
        {projectImage ? (
          <Image
            src={projectImage}
            alt={project.imageAlt}
            widths={[400, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 800px"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="w-full h-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center">
            <span class="mono-label">{data.ui.project.visual}</span>
          </div>
        )}
      </div>

      {project.metrics && project.metrics.length > 0 && (
        <div class="scroll-reveal grid grid-cols-3 gap-[1px] bg-zinc-200 dark:bg-zinc-800 mb-12" style="transition-delay: 150ms">
          {project.metrics.map((metric) => (
            <div class="bg-white dark:bg-zinc-900/80 p-6 text-center">
              <p class="font-display text-2xl md:text-3xl font-bold text-accent-500 mb-1">{metric.value}</p>
              <p class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">{metric.label}</p>
            </div>
          ))}
        </div>
      )}

      <p class="scroll-reveal text-base text-zinc-600 dark:text-zinc-400 leading-relaxed mb-12 max-w-2xl" style="transition-delay: 200ms">
        {project.longDescription}
      </p>

      <div class="scroll-reveal mb-12" style="transition-delay: 250ms">
        <span class="mono-label mb-4 block">{data.ui.project.technologies}</span>
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="font-mono text-[10px] uppercase tracking-wider px-3 py-1.5 border border-zinc-200 dark:border-zinc-800 text-zinc-600 dark:text-zinc-400 hover:border-accent-500/50 hover:text-accent-500 transition-colors duration-200">
              {tech}
            </span>
          ))}
        </div>
      </div>

      <div class="scroll-reveal flex flex-wrap gap-4 border-t border-zinc-200 dark:border-zinc-800 pt-8" style="transition-delay: 300ms">
        {project.demoUrl && (
          <a
            href={project.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 px-5 py-2.5 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"

          >
            {data.ui.project.demo}
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}
        {project.githubUrl && (
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 px-5 py-2.5 border border-zinc-200 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-sm font-medium hover:border-accent-500 hover:text-accent-500 transition-colors duration-200"

          >
            {data.ui.project.source}
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
