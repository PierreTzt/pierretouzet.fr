---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import SkillBar from '../../components/SkillBar.astro';
import { getData } from '../../i18n/utils';

const lang = 'fr';
const data = getData(lang);
---

<BaseLayout
  title={`${data.ui.nav.skills} — ${data.personal.name}`}
  description={`Compétences techniques de ${data.personal.name}`}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: '/fr/' },
    { name: data.ui.nav.skills, url: '/fr/competences/' },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto">
      <SectionHeader title={data.ui.services.title} number="01" as="h1" />

      <div class="grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800 mb-16">
        {data.services.map((service, i) => (
          <div class="scroll-reveal tile p-8" style={`transition-delay: ${i * 100}ms`}>
            <span class="font-mono text-[10px] text-accent-500 mb-3 block">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{service.title}</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">{service.description}</p>
            <div class="flex flex-wrap gap-2">
              {service.examples.map((ex) => (
                <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
                  {ex}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <SectionHeader title={data.ui.sections.allSkills} number="02" />

      <div class="grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
        {data.skillCategories.map((category, catIdx) => (
          <div class="scroll-reveal tile p-8" style={`transition-delay: ${catIdx * 100}ms`}>
            <div class="flex items-start gap-3 mb-2">
              {category.icon && (
                <svg class="w-5 h-5 text-accent-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={category.icon} />
                </svg>
              )}
              <p class="mono-label">{category.name}</p>
            </div>
            {category.description && (
              <p class="text-xs text-zinc-500 dark:text-zinc-400 mb-6 leading-relaxed">
                {category.description}
              </p>
            )}
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill, i) => (
                <SkillBar skill={skill} index={catIdx * 6 + i} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
