---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import Process from '../../components/Process.astro';
import { getData } from '../../i18n/utils';

const lang = 'fr';
const data = getData(lang);
---

<BaseLayout
  title={`${data.ui.consulting.title} — ${data.personal.name}`}
  description={data.ui.consulting.subtitle}
  lang={lang}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={data.ui.consulting.title} subtitle={data.ui.consulting.subtitle} number="01" as="h1" />

      <!-- Services -->
      <div class="scroll-reveal mb-16">
        <span class="mono-label mb-6 block">{data.ui.services.title}</span>
        <div class="grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
          {data.services.map((service, i) => (
            <div class="tile p-6">
              <span class="font-mono text-[10px] text-accent-500 mb-3 block">{String(i + 1).padStart(2, '0')}</span>
              <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{service.title}</h2>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">{service.description}</p>
              <div class="flex flex-wrap gap-2">
                {service.examples.map((ex) => (
                  <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
                    {ex}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Process -->
      <div class="scroll-reveal mb-16" style="transition-delay: 100ms">
        <span class="mono-label mb-6 block">{data.ui.process.title}</span>
        <div class="grid md:grid-cols-4 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
          {data.processSteps.map((step, i) => (
            <div class="tile p-6 text-center">
              <span class="font-mono text-[10px] text-accent-500 mb-2 block">{step.number}</span>
              <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{step.title}</h3>
              <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Key metrics -->
      <div class="scroll-reveal mb-16" style="transition-delay: 150ms">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
          {data.keyMetrics.map((m) => (
            <div class="tile p-6 text-center">
              <p class="font-display text-2xl font-bold text-accent-500 mb-1">{m.value}</p>
              <p class="font-mono text-[10px] uppercase tracking-wider text-zinc-500">{m.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Cas typiques -->
      <div class="scroll-reveal mb-16" style="transition-delay: 175ms">
        <span class="mono-label mb-6 block">Vous vous reconnaissez ?</span>
        <div class="space-y-[1px] bg-zinc-200 dark:bg-zinc-800">
          <div class="tile p-6">
            <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">Vous êtes directeur d'école et vos programmes datent</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">Je vous accompagne sur l'audit, la refonte des maquettes et la mise en conformité RNCP/Qualiopi. De la conception à la certification.</p>
          </div>
          <div class="tile p-6">
            <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">Vos équipes pédagogiques perdent du temps sur des tâches administratives</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">J'identifie les outils, je déploie, je forme. Objectif : diviser le temps admin par 2 ou 3. Adoption garantie.</p>
          </div>
          <div class="tile p-6">
            <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">Vous voulez intégrer l'IA dans vos formations mais ne savez pas par où commencer</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">Audit de maturité, montée en compétences des équipes, définition d'une stratégie réaliste. Un regard de praticien, pas de théoricien.</p>
          </div>
        </div>
      </div>

      <!-- Format de mission -->
      <div class="scroll-reveal mb-16" style="transition-delay: 185ms">
        <span class="mono-label mb-6 block">Formats de mission</span>
        <div class="grid md:grid-cols-3 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
          <div class="tile p-6 text-center">
            <p class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-2">Diagnostic</p>
            <p class="font-mono text-[10px] text-accent-500 mb-2">1 à 3 jours</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400">Audit rapide, recommandations actionnables, plan d'action priorisé.</p>
          </div>
          <div class="tile p-6 text-center">
            <p class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-2">Mission</p>
            <p class="font-mono text-[10px] text-accent-500 mb-2">1 à 6 mois</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400">Accompagnement complet : conception, déploiement, formation, suivi.</p>
          </div>
          <div class="tile p-6 text-center">
            <p class="font-display text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-2">Conseil ponctuel</p>
            <p class="font-mono text-[10px] text-accent-500 mb-2">À la demande</p>
            <p class="text-xs text-zinc-500 dark:text-zinc-400">Échanges ponctuels, revue de projet, expertise ciblée.</p>
          </div>
        </div>
      </div>

      <!-- Testimonials -->
      <div class="scroll-reveal mb-16" style="transition-delay: 200ms">
        <span class="mono-label mb-4 block">{data.ui.testimonials.title}</span>
        <div class="space-y-4">
          {data.testimonials.slice(0, 2).map((t) => (
            <blockquote class="tile p-6">
              <p class="text-sm text-zinc-500 dark:text-zinc-400 italic leading-relaxed mb-3">"{t.quote}"</p>
              <p class="font-mono text-[10px] uppercase tracking-wider text-zinc-500">
                {t.name} — {t.role}, {t.company}
              </p>
            </blockquote>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="scroll-reveal text-center" style="transition-delay: 250ms">
        <a
          href={`mailto:${data.personal.email}?subject=${encodeURIComponent("Demande de consulting")}`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.contact.letsTalk}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
