---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getData } from '../i18n/utils';

const frData = getData('fr');
const enData = getData('en');
---

<BaseLayout title="404" description="Page introuvable — Page not found" lang="fr">
  <section class="min-h-[70vh] flex items-center justify-center px-6 relative overflow-hidden">
    <!-- Floating particles -->
    <div class="particles" aria-hidden="true">
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
      <span class="particle"></span>
    </div>

    <div class="text-center relative z-10">
      <p class="font-mono text-accent-500/40 text-[11px] uppercase tracking-[0.3em] mb-6 animate-pulse">Error</p>

      <!-- Big animated 404 -->
      <div class="glitch-wrapper mb-8" aria-hidden="true">
        <p class="glitch font-display text-[8rem] md:text-[12rem] leading-none font-extrabold text-zinc-100 dark:text-zinc-800/50 select-none" data-text="404">404</p>
      </div>

      <h1 class="font-display text-2xl md:text-3xl mb-4 -mt-16 md:-mt-20 relative">
        <span class="text-zinc-900 dark:text-zinc-50 font-bold">{frData.ui.notFound.title}</span>
      </h1>

      <p class="text-sm text-zinc-500 mb-12 max-w-sm mx-auto leading-relaxed">
        {frData.ui.notFound.message}<br />
        <span class="text-zinc-400">{enData.ui.notFound.message}</span>
      </p>

      <div class="flex items-center justify-center gap-6">
        <a
          href="/fr/"
          class="group inline-flex items-center gap-2 px-5 py-2.5 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          <svg class="w-3.5 h-3.5 group-hover:-translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          {frData.ui.notFound.backHome}
        </a>
        <a
          href="/en/"
          class="mono-label hover:text-accent-500 transition-colors duration-200"
        >
          English &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Glitch effect on 404 */
  .glitch-wrapper {
    position: relative;
  }

  .glitch {
    position: relative;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.6;
  }

  .glitch::before {
    color: #4f46e5;
    animation: glitch-1 3s infinite linear alternate-reverse;
    clip-path: inset(0 0 60% 0);
  }

  .glitch::after {
    color: #818cf8;
    animation: glitch-2 3s infinite linear alternate-reverse;
    clip-path: inset(40% 0 0 0);
  }

  @keyframes glitch-1 {
    0%, 90% { transform: translate(0); }
    92% { transform: translate(-3px, 1px); }
    94% { transform: translate(3px, -1px); }
    96% { transform: translate(-2px, 2px); }
    98% { transform: translate(2px, 0); }
    100% { transform: translate(0); }
  }

  @keyframes glitch-2 {
    0%, 90% { transform: translate(0); }
    91% { transform: translate(2px, -1px); }
    93% { transform: translate(-3px, 1px); }
    95% { transform: translate(1px, 2px); }
    97% { transform: translate(-2px, -1px); }
    100% { transform: translate(0); }
  }

  /* Floating particles */
  .particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #4f46e5;
    opacity: 0.15;
    animation: float linear infinite;
  }

  .particle:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; width: 3px; height: 3px; }
  .particle:nth-child(2) { left: 30%; animation-duration: 16s; animation-delay: -3s; width: 5px; height: 5px; }
  .particle:nth-child(3) { left: 55%; animation-duration: 14s; animation-delay: -6s; }
  .particle:nth-child(4) { left: 75%; animation-duration: 18s; animation-delay: -2s; width: 3px; height: 3px; }
  .particle:nth-child(5) { left: 90%; animation-duration: 13s; animation-delay: -8s; width: 6px; height: 6px; }

  @keyframes float {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.15; }
    90% { opacity: 0.15; }
    100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch::before,
    .glitch::after,
    .particle {
      animation: none !important;
    }
  }
</style>
