---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getData } from '../../i18n/utils';

const lang = 'en';
const data = getData(lang);
---

<BaseLayout
  title={`${data.ui.speaker.title} — ${data.personal.name}`}
  description={data.ui.speaker.subtitle}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: '/en/' },
    { name: data.ui.speaker.title, url: '/en/speaker/' },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={data.ui.speaker.title} subtitle={data.ui.speaker.subtitle} number="01" as="h1" />

      <div class="space-y-[1px] bg-zinc-200 dark:bg-zinc-800 mb-12">
        {data.speakerTopics.map((topic, i) => (
          <div class="scroll-reveal tile p-8" style={`transition-delay: ${i * 100}ms`}>
            <div class="flex items-start justify-between gap-4 mb-3">
              <span class="font-mono text-[10px] text-accent-500">{String(i + 1).padStart(2, '0')}</span>
              <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-400 dark:text-zinc-500 shrink-0">
                {topic.format}
              </span>
            </div>
            <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-3">{topic.title}</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">{topic.abstract}</p>
            <div class="flex flex-wrap gap-2">
              {topic.tags.map((tag) => (
                <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 bg-accent-500/10 text-accent-600 dark:text-accent-400">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="scroll-reveal text-center" style="transition-delay: 300ms">
        <a
          href={`mailto:${data.personal.email}?subject=${encodeURIComponent("Speaking invitation")}`}
          class="group inline-flex items-center gap-3 px-8 py-4 bg-zinc-900 dark:bg-zinc-100 text-zinc-50 dark:text-zinc-900 text-sm font-medium hover:bg-accent-600 dark:hover:bg-accent-500 dark:hover:text-white transition-all duration-200"
        >
          {data.ui.speaker.cta}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
