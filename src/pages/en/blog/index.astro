---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { getData } from '../../../i18n/utils';

const lang = 'en';
const data = getData(lang);

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title={`${data.ui.blog.title} — ${data.personal.name}`}
  description={data.ui.blog.subtitle}
  lang={lang}
  breadcrumbs={[
    { name: data.ui.nav.home, url: '/en/' },
    { name: data.ui.blog.title, url: '/en/blog/' },
  ]}
>
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeader title={data.ui.blog.title} subtitle={data.ui.blog.subtitle} number="01" as="h1" />

      {posts.length === 0 ? (
        <div class="tile p-12 text-center">
          <p class="text-sm text-zinc-500 dark:text-zinc-400">{data.ui.blog.empty}</p>
        </div>
      ) : (
        <div class="space-y-[1px] bg-zinc-200 dark:bg-zinc-800">
          {posts.map((post, i) => (
            <a
              href={`/en/blog/${post.slug}/`}
              class="scroll-reveal tile tile-interactive glow-hover group block p-8"
              style={`transition-delay: ${i * 80}ms`}
            >
              <div class="flex items-start justify-between gap-4 mb-3">
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-0.5 bg-accent-500/10 text-accent-600 dark:text-accent-400">
                      {tag}
                    </span>
                  ))}
                </div>
                <time class="font-mono text-[10px] text-zinc-400 shrink-0" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-accent-500 transition-colors duration-200 mb-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed line-clamp-2">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
