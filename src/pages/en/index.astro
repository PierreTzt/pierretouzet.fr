---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Metrics from '../../components/Metrics.astro';
import SkillBar from '../../components/SkillBar.astro';
import Process from '../../components/Process.astro';
import EbookCta from '../../components/EbookCta.astro';
import Testimonials from '../../components/Testimonials.astro';
import { getData } from '../../i18n/utils';

const lang = 'en';
const data = getData(lang);
const featured = data.projects.filter((p) => p.featured);
const latestExp = data.experiences[0];
const topCategory = data.skillCategories[0];
---

<BaseLayout
  title={`${data.personal.name} — ${data.personal.title}`}
  description={data.personal.description}
  lang={lang}
>
  <Hero lang={lang} />

  <Metrics metrics={data.keyMetrics} trustedBy="Trusted by" />

  <section class="px-6 pb-6">
    <div class="max-w-7xl mx-auto">
      <!-- Row 1 -->
      <div class="grid md:grid-cols-[2fr_1fr] gap-[1px] bg-zinc-200 dark:bg-zinc-800 mb-[1px]">
        <a
          href={`/en/projects/${featured[0].slug}/`}
          class="tile tile-interactive glow-hover group p-8 md:p-10 flex flex-col justify-between min-h-[320px]"

        >
          <div>
            <div class="flex items-center justify-between mb-6">
              <span class="mono-label">{data.ui.sections.latestProjects}</span>
              <span class="font-mono text-[10px] text-accent-500">01</span>
            </div>
            <h2 class="font-display text-heading text-zinc-900 dark:text-zinc-50 group-hover:text-accent-500 transition-colors duration-200 font-bold mb-4">
              {featured[0].title}
            </h2>
            <p class="text-sm text-zinc-500 leading-relaxed max-w-lg">{featured[0].shortDescription}</p>
          </div>
          <div class="flex items-center justify-between mt-8">
            <div class="flex flex-wrap gap-2">
              {featured[0].technologies.slice(0, 4).map((t) => (
                <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">{t}</span>
              ))}
            </div>
            <svg class="w-4 h-4 text-zinc-500 group-hover:text-accent-500 group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
        </a>

        <div class="tile p-8 flex flex-col justify-between min-h-[320px]">
          <div>
            <span class="mono-label mb-6 block">{data.ui.status.label}</span>
            <div class="flex items-center gap-2 mb-4">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
              <span class="text-sm text-zinc-600 dark:text-zinc-400">{data.ui.status.available}</span>
            </div>
            <p class="font-display text-lg font-light text-zinc-700 dark:text-zinc-300">{data.personal.location}</p>
          </div>
          <div class="space-y-3 mt-6">
            {data.social.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="flex items-center justify-between py-2 border-t border-zinc-100 dark:border-zinc-800 group/link">
                <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 group-hover/link:text-accent-500 transition-colors">{s.platform}</span>
                <svg class="w-3 h-3 text-zinc-300 group-hover/link:text-accent-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
              </a>
            ))}
            <a href={`mailto:${data.personal.email}`} aria-label={data.ui.contact.emailMe} class="flex items-center justify-between py-2 border-t border-zinc-100 dark:border-zinc-800 group/link">
              <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400 group-hover/link:text-accent-500 transition-colors">Email</span>
              <svg class="w-3 h-3 text-zinc-300 group-hover/link:text-accent-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Row 2 -->
      <div class="grid md:grid-cols-3 gap-[1px] bg-zinc-200 dark:bg-zinc-800 mb-[1px]">
        {featured.slice(1, 3).map((project, i) => (
          <a href={`/en/projects/${project.slug}/`} class="tile tile-interactive glow-hover group p-6 flex flex-col justify-between min-h-[260px]">
            <div>
              <span class="font-mono text-[10px] text-accent-500 mb-4 block">{String(i + 2).padStart(2, '0')}</span>
              <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-accent-500 transition-colors duration-200 mb-2">{project.title}</h2>
              <p class="text-sm text-zinc-500 leading-relaxed line-clamp-3">{project.shortDescription}</p>
            </div>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.technologies.slice(0, 3).map((t) => (
                <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 dark:text-zinc-400">{t}</span>
              ))}
            </div>
          </a>
        ))}
        <div class="tile p-6 flex flex-col justify-between min-h-[260px]">
          <div>
            <span class="mono-label mb-4 block">{data.ui.sections.latestExperiences}</span>
            <p class="font-mono text-xs text-zinc-500 dark:text-zinc-400 mb-3">{latestExp.startDate} — {latestExp.endDate}</p>
            <h2 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-1">{latestExp.position}</h2>
            <p class="text-sm text-accent-500 font-medium mb-3">{latestExp.company}</p>
            <p class="text-sm text-zinc-500 leading-relaxed line-clamp-3">{latestExp.description}</p>
          </div>
          <a href="/en/experiences/" class="mono-label hover:text-accent-500 transition-colors duration-200 mt-4">{data.ui.sections.viewAll} →</a>
        </div>
      </div>

      <!-- Row 3 -->
      <div class="grid md:grid-cols-[2fr_1fr] gap-[1px] bg-zinc-200 dark:bg-zinc-800">
        <div class="tile p-8">
          <div class="flex items-center justify-between mb-6">
            <span class="mono-label">{data.ui.sections.topSkills}</span>
            <a href="/en/skills/" class="mono-label hover:text-accent-500 transition-colors duration-200">{data.ui.sections.viewAll} →</a>
          </div>
          <div class="flex flex-wrap gap-2">
            {topCategory.skills.map((skill, i) => (
              <SkillBar skill={skill} index={i} />
            ))}
          </div>
        </div>

        <a href="/en/contact/" class="group relative overflow-hidden p-8 flex flex-col justify-between min-h-[200px] bg-gradient-to-br from-zinc-900 via-zinc-800 to-zinc-900 dark:from-zinc-100 dark:via-zinc-200 dark:to-zinc-100">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-500/10 via-electric-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-500 relative z-10">Contact</span>
          <div class="relative z-10">
            <p class="font-display text-heading text-zinc-50 dark:text-zinc-900 mb-4 font-bold">{data.ui.contact.letsTalk}</p>
            <div class="flex items-center gap-2">
              <span class="font-mono text-[10px] uppercase tracking-wider text-zinc-400 dark:text-zinc-600 group-hover:text-accent-500 transition-colors">{data.personal.email}</span>
              <svg class="w-3.5 h-3.5 text-zinc-400 dark:text-zinc-600 group-hover:text-accent-500 group-hover:translate-x-0.5 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </div>
          </div>
        </a>
      </div>

      <div class="mt-8 mb-8 flex justify-end">
        <a href="/en/projects/" class="group mono-label hover:text-accent-500 transition-colors duration-200 flex items-center gap-2">
          {data.ui.sections.allProjects}
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <Process
    steps={data.processSteps}
    title={data.ui.process.title}
    subtitle={data.ui.process.subtitle}
  />

  <EbookCta lang={lang} />

  <Testimonials
    testimonials={data.testimonials}
    title={data.ui.testimonials.title}
    subtitle={data.ui.testimonials.subtitle}
  />

  <!-- Double entry -->
  <section class="px-6 pb-24">
    <div class="max-w-7xl mx-auto">
      <div class="scroll-reveal grid md:grid-cols-2 gap-[1px] bg-zinc-200 dark:bg-zinc-800">
        <a href="/en/hiring/" class="tile tile-interactive glow-hover group p-8 flex flex-col justify-between min-h-[160px]">
          <span class="mono-label">{data.ui.hiring.title}</span>
          <div class="flex items-center justify-between mt-4">
            <p class="text-sm text-zinc-500 dark:text-zinc-400">{data.ui.hiring.subtitle}</p>
            <svg class="w-4 h-4 text-zinc-300 group-hover:text-accent-500 group-hover:translate-x-0.5 transition-all duration-200 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
        <a href="/en/consulting/" class="tile tile-interactive glow-hover group p-8 flex flex-col justify-between min-h-[160px]">
          <span class="mono-label">{data.ui.consulting.title}</span>
          <div class="flex items-center justify-between mt-4">
            <p class="text-sm text-zinc-500 dark:text-zinc-400">{data.ui.consulting.subtitle}</p>
            <svg class="w-4 h-4 text-zinc-300 group-hover:text-accent-500 group-hover:translate-x-0.5 transition-all duration-200 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

