{
  "name": "portfolio-cv-pierre",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{astro,ts,tsx,js,mjs,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,tsx,js,mjs,css,json,md}\"",
    "test": "vitest run",
    "check:parity": "npx tsx src/utils/check-parity.ts",
    "validate": "npm run check && npm run lint && npm run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/tailwind": "^6.0.2",
    "@astrojs/vercel": "^9.0.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/sora": "^5.2.8",
    "@sentry/astro": "^10.45.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.6.1",
    "astro": "^5.17.1",
    "satori": "^0.25.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "puppeteer": "^24.37.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{astro,ts,tsx,js,mjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  }
}
